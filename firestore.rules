rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Grupos: leitura e envio públicos; alterar só logado (admin).
    match /grupos/{document} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // configs/ads — leitura pública para o SSR (Layout) saber se anúncios estão ativos.
    // Escrita só com usuário autenticado (painel admin).
    match /configs/{configId} {
      allow read: if configId == "ads";
      allow create, update, delete: if request.auth != null;
    }

    // Pesquisas na página de categorias — gravação anônima validada; leitura só admin.
    match /pesquisas_grupos/{docId} {
      allow create: if request.resource.data.keys().hasOnly(["termo", "termoNormalizado", "resultados", "origem", "criadoEm"])
        && request.resource.data.termo is string
        && request.resource.data.termo.size() > 0
        && request.resource.data.termo.size() <= 200
        && request.resource.data.termoNormalizado is string
        && request.resource.data.termoNormalizado.size() <= 200
        && request.resource.data.resultados is int
        && request.resource.data.resultados >= 0
        && request.resource.data.resultados < 100000
        && request.resource.data.origem == "categorias"
        && request.resource.data.criadoEm is timestamp;
      // list = consultas na collection; get = ler um documento (explícito ajuda em alguns casos)
      allow list, get: if request.auth != null;
      allow update, delete: if false;
    }

    // Leads (e-mail ao enviar/editar grupo) — create público com validação mínima.
    match /leads/{docId} {
      allow create: if request.resource.data.keys().hasOnly(["email", "origem", "data"])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320
        && request.resource.data.origem is string
        && request.resource.data.origem in ["enviar-grupo", "editar-grupo"]
        && request.resource.data.data is timestamp;
      allow read, update, delete: if request.auth != null;
    }
  }
}
