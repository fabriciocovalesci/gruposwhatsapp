---
interface Props {
  id?: string;
  nome: string;
  descricao: string;
  categoria: string;
  tipo: 'grupo' | 'canal';
  link: string;
  membros?: number;
  destaque?: boolean;
  foto?: string;
  tags?: string[];
}

const { nome, descricao, categoria, tipo, link, membros, foto, destaque, tags = [] } = Astro.props;
const isCanal = tipo === 'canal';
const membrosStr = membros != null ? membros.toLocaleString('pt-BR') : null;
const avatarUrl = foto
  ?? `https://ui-avatars.com/api/?name=${encodeURIComponent(nome.slice(0, 2))}&background=${isCanal ? '25D366' : '128C7E'}&color=fff&size=128&bold=true&rounded=true`;
---

<div
  class="card-grupo bg-white shadow overflow-hidden transition border-transparent border-l-4 hover:border-yellow-300"
  data-nome={nome.toLowerCase()}
  data-descricao={descricao.toLowerCase()}
  data-categoria={categoria}
  data-tipo={tipo}
>
  <div class="flex items-start gap-4 p-4 xxl:p-6">

    <!-- Avatar -->
    <img
      src={avatarUrl}
      alt={nome}
      width="48"
      height="48"
      class="size-12 shrink-0 rounded-full object-cover border border-gray-100"
    />

    <!-- Conteudo -->
    <div class="flex-1 min-w-0">
      <!-- Nome + badges -->
      <div class="flex flex-wrap items-center gap-2 mb-1">
        <h3 class="h6 truncate">{nome}</h3>
        <span class={`text-sm font-semibold px-2 py-0.5 rounded ${isCanal ? 'bg-green-100 text-green-700' : 'bg-teal-100 text-teal-700'}`}>
          {isCanal ? 'Canal' : 'Grupo'}
        </span>
        {destaque && (
          <span class="bg-yellow-200 text-gray-800 text-sm font-semibold px-2 py-0.5 rounded">
            Destaque
          </span>
        )}
      </div>

      <!-- Membros -->
      {membrosStr && (
        <p class="text-base text-gray-400 mb-1">{membrosStr} membros</p>
      )}

      <!-- Descricao -->
      <p class="text-base line-clamp-2 text-gray-600">{descricao}</p>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1 mt-2">
          {tags.slice(0, 4).map(tag => (
            <span class="text-sm bg-gray-100 text-gray-500 px-2 py-0.5 rounded">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- Rodape -->
  <div class="flex items-center justify-between px-4 xxl:px-6 pb-4 gap-4">
    <a
      href={`/grupos/categoria/${categoria}`}
      class="text-base text-gray-400 hover:text-gray-800 hover:underline transition truncate"
    >
      {categoria}
    </a>
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="button button-black shrink-0"
    >
      Entrar
      <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 size-4 inline-block" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
      </svg>
    </a>
  </div>
</div>
