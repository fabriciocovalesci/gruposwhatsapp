---
// Componente puramente de apresentação — toda a lógica fica no <script>
// Sem import.meta.env aqui: Firebase é inicializado em ~/lib/firebase.ts
---

<!-- Tela de login -->
<div id="tela-login" class="min-h-[70vh] flex items-center justify-center px-4">
  <div class="bg-white shadow-md p-8 w-full max-w-sm">
    <h1 class="h4 mb-1">Acesso restrito</h1>
    <p class="text-base text-gray-500 mb-6">Painel de moderação WhatsDir</p>

    <div
      id="erro-login"
      class="hidden mb-4 text-base text-red-700 bg-red-50 border border-red-200 rounded px-3 py-2"
    >
    </div>

    <label for="input-email">E-mail</label>
    <input id="input-email" type="email" placeholder="admin@exemplo.com" />

    <label for="input-senha" class="mt-4">Senha</label>
    <input id="input-senha" type="password" placeholder="" />

    <button id="btn-login" class="button button-yellow w-full mt-6"
      >Entrar</button
    >
  </div>
</div>

<!-- Painel -->
<div id="painel" class="hidden">
  <!-- Cabeçalho -->
  <section class="bg-yellow-200">
    <div class="container py-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h1 class="h4">Painel de moderação</h1>
          <p id="label-usuario" class="text-base text-gray-600 mt-0.5"></p>
          <div class="flex items-center gap-3 lg:gap-6">
            <label
              class="flex items-center cursor-pointer gap-2 bg-yellow-300/50 px-3 py-1.5 rounded-lg border border-yellow-400/50"
            >
              <span class="text-xs font-bold text-gray-800 hidden sm:block"
                >ADS Ativos</span
              >
              <div class="relative">
                <input
                  type="checkbox"
                  id="toggle-ads"
                  class="sr-only peer"
                  checked
                />
                <div
                  class="w-9 h-5 bg-gray-300 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-[#028b3a]"
                >
                </div>
              </div>
            </label>
            <button
              id="btn-sair"
              class="button button-black !px-4 !py-1.5 !text-sm">Sair</button
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Abas -->
  <section class="bg-white border-b border-gray-200">
    <div class="container">
      <div class="flex gap-0">
        <button
          class="aba-btn px-6 py-4 text-base font-semibold border-b-2 border-yellow-300 text-gray-800"
          data-aba="pendente"
        >
          Pendentes <span
            id="badge-pendente"
            class="ml-2 bg-yellow-200 text-gray-800 text-sm px-2 py-0.5 rounded"
          ></span>
        </button>
        <button
          class="aba-btn px-6 py-4 text-base font-semibold border-b-2 border-transparent text-gray-400 hover:text-gray-800 transition"
          data-aba="aprovado"
        >
          Aprovados
        </button>
        <button
          class="aba-btn px-6 py-4 text-base font-semibold border-b-2 border-transparent text-gray-400 hover:text-gray-800 transition"
          data-aba="rejeitado"
        >
          Rejeitados
        </button>
        <button
          class="aba-btn px-6 py-4 text-base font-semibold border-b-2 border-transparent text-gray-400 hover:text-gray-800 transition"
          data-aba="pesquisas"
        >
          Pesquisas
        </button>
      </div>
    </div>
  </section>

  <!-- Lista -->
  <section class="bg-gray-50 min-h-screen">
    <div class="container py-8">
      <div
        id="loading-grupos"
        class="flex items-center gap-3 py-16 text-gray-400"
      >
        <svg class="animate-spin size-5" viewBox="0 0 24 24" fill="none">
          <circle
            class="opacity-25"
            cx="12"
            cy="12"
            r="10"
            stroke="currentColor"
            stroke-width="4"></circle>
          <path
            class="opacity-75"
            fill="currentColor"
            d="M4 12a8 8 0 018-8v8H4z"></path>
        </svg>
        Carregando grupos...
      </div>
      <div id="lista-vazia" class="hidden text-center py-16 text-gray-400">
        <p class="text-5xl mb-4">📭</p>
        <p class="text-lg font-semibold">Nenhum grupo aqui</p>
      </div>
      <div id="lista-grupos" class="hidden space-y-4"></div>
      <div id="lista-pesquisas" class="hidden space-y-4">
        <div
          id="pesquisas-filtros"
          class="rounded-2xl border border-gray-200/90 bg-white p-4 shadow-sm ring-1 ring-black/[0.04]"
        >
          <p
            class="text-[11px] font-black uppercase tracking-widest text-gray-400 mb-3"
          >
            Filtros
          </p>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-12 lg:items-end">
            <div class="lg:col-span-2">
              <label
                for="pesq-data-de"
                class="mb-1 block text-xs font-semibold text-gray-600"
                >Data inicial</label
              >
              <input
                type="date"
                id="pesq-data-de"
                autocomplete="off"
                class="w-full min-h-11 rounded-xl border border-gray-200 bg-gray-50/80 px-3 text-sm text-gray-900 outline-none transition focus:border-emerald-500 focus:bg-white focus:ring-2 focus:ring-emerald-500/20"
              />
            </div>
            <div class="lg:col-span-2">
              <label
                for="pesq-data-ate"
                class="mb-1 block text-xs font-semibold text-gray-600"
                >Data final</label
              >
              <input
                type="date"
                id="pesq-data-ate"
                autocomplete="off"
                class="w-full min-h-11 rounded-xl border border-gray-200 bg-gray-50/80 px-3 text-sm text-gray-900 outline-none transition focus:border-emerald-500 focus:bg-white focus:ring-2 focus:ring-emerald-500/20"
              />
            </div>
            <div class="sm:col-span-2 lg:col-span-4">
              <label
                for="pesq-termo"
                class="mb-1 block text-xs font-semibold text-gray-600"
                >Termo contém</label
              >
              <input
                type="search"
                id="pesq-termo"
                enterkeyhint="search"
                placeholder="Ex.: figurinha, emprego…"
                class="w-full min-h-11 rounded-xl border border-gray-200 bg-gray-50/80 px-3 text-sm text-gray-900 outline-none transition placeholder:text-gray-400 focus:border-emerald-500 focus:bg-white focus:ring-2 focus:ring-emerald-500/20"
              />
            </div>
            <div
              class="flex flex-col gap-2 sm:flex-row sm:col-span-2 lg:col-span-4"
            >
              <button
                type="button"
                id="pesq-btn-filtrar"
                class="min-h-11 flex-1 touch-manipulation rounded-xl bg-emerald-600 px-4 text-sm font-bold text-white shadow-sm transition hover:bg-emerald-700 active:scale-[0.98]"
              >
                Filtrar
              </button>
              <button
                type="button"
                id="pesq-btn-limpar"
                class="min-h-11 touch-manipulation rounded-xl border border-gray-200 bg-white px-4 text-sm font-bold text-gray-700 transition hover:bg-gray-50 active:scale-[0.98]"
              >
                Limpar
              </button>
            </div>
          </div>
          <p
            id="pesquisas-filtro-aviso"
            class="mt-2 hidden text-[11px] text-amber-700/90"
          >
          </p>
        </div>

        <ul
          id="pesquisas-cards"
          class="md:hidden space-y-2.5"
          aria-label="Lista de pesquisas"
        >
        </ul>

        <div
          class="hidden md:block overflow-hidden rounded-2xl border border-gray-200/90 bg-white shadow-sm ring-1 ring-black/[0.04]"
        >
          <div class="overflow-x-auto">
            <table class="w-full min-w-[560px] text-left text-sm">
              <thead>
                <tr
                  class="bg-gradient-to-r from-slate-800 to-slate-900 text-[11px] font-bold uppercase tracking-wider text-white/95"
                >
                  <th class="px-4 py-3 whitespace-nowrap w-[92px]">Data</th>
                  <th class="px-4 py-3 whitespace-nowrap w-[80px]">Hora</th>
                  <th class="px-4 py-3">Termo</th>
                  <th
                    class="px-4 py-3 w-14 text-center"
                    title="Grupos encontrados">#</th>
                </tr>
              </thead>
              <tbody
                id="pesquisas-tbody"
                class="divide-y divide-gray-100 text-gray-800"
              >
              </tbody>
            </table>
          </div>
        </div>

        <div
          class="flex flex-col gap-3 rounded-2xl border border-gray-100 bg-gray-50/80 px-3 py-3 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between"
        >
          <button
            type="button"
            id="pesquisas-prev"
            class="min-h-11 touch-manipulation rounded-xl border border-gray-200 bg-white px-4 text-sm font-bold text-gray-800 shadow-sm transition hover:bg-white disabled:pointer-events-none disabled:opacity-35 sm:order-1"
          >
            ← Anterior
          </button>
          <span
            id="pesquisas-page-meta"
            class="order-3 text-center text-xs font-medium leading-snug text-gray-600 sm:order-2 sm:max-w-[55%] sm:flex-1"
          ></span>
          <button
            type="button"
            id="pesquisas-next"
            class="min-h-11 touch-manipulation rounded-xl border border-gray-200 bg-white px-4 text-sm font-bold text-gray-800 shadow-sm transition hover:bg-white disabled:pointer-events-none disabled:opacity-35 sm:order-3"
          >
            Próxima →
          </button>
        </div>
      </div>
      <div id="vazio-pesquisas" class="hidden text-center py-16 text-gray-400">
        <p class="text-5xl mb-4">🔎</p>
        <p class="text-lg font-semibold msg">Nenhuma pesquisa registrada ainda</p>
        <p class="err-detail text-xs mt-3 max-w-lg mx-auto text-red-600 font-mono whitespace-pre-wrap hidden">
        </p>
        <p class="text-sm mt-2 max-w-md mx-auto text-gray-500 hint">
          Quando alguém usar “Buscar grupos” (home → categorias), o termo e a data/hora são
          gravados na collection
          <code class="text-xs bg-gray-100 px-1 rounded text-gray-700">pesquisas_grupos</code>.
          Confira se as regras do Firestore foram publicadas.
        </p>
      </div>
    </div>
  </section>
</div>

<!-- Template do card -->
<template id="tpl-card">
  <div
    class="card-grupo bg-white shadow-sm overflow-hidden transition border-transparent border-l-4 rounded-xl border-gray-100"
  >
    <div class="flex items-start gap-3 p-3 lg:p-4">
      <img
        class="c-foto size-10 shrink-0 rounded-lg object-cover bg-gray-50"
        src=""
        alt=""
      />
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center gap-1.5 mb-0.5">
          <h3 class="c-nome text-sm font-bold truncate"></h3>
          <span
            class="c-tipo text-[10px] font-black px-1.5 py-0.5 rounded uppercase tracking-tighter"
          ></span>
        </div>
        <p class="c-cat text-[11px] text-[#25D366] font-bold mb-1"></p>
        <p class="c-desc text-xs text-gray-500 line-clamp-1"></p>
      </div>
    </div>
    <div
      class="flex items-center justify-between px-3 pb-3 pt-1 border-t border-gray-50 mt-1"
    >
      <a
        class="c-link text-xs text-gray-400 font-bold hover:text-gray-900"
        href="#"
        target="_blank"
        rel="noopener noreferrer">LINK</a
      >
      <div class="flex gap-2">
        <button
          class="c-destaque p-2 text-gray-300 hover:text-yellow-500 rounded-lg transition"
          title="Destaque"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-4"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
            ></path>
          </svg>
        </button>
        <button
          class="c-excluir p-2 text-red-500 hover:bg-red-50 rounded-lg transition"
          title="Excluir"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
            ></path>
          </svg>
        </button>
        <button
          class="c-rejeitar hidden px-3 py-1.5 bg-gray-100 text-gray-600 rounded-lg text-xs font-bold hover:bg-gray-200 uppercase"
          >Rejeitar</button
        >
        <button
          class="c-aprovar hidden px-3 py-1.5 bg-yellow-200 text-gray-800 rounded-lg text-xs font-bold hover:bg-yellow-300 uppercase"
          >Aprovar</button
        >
      </div>
    </div>
  </div>
</template>

<script>
  // Auth permanece client-side (Firebase Auth exige estado no browser)
  // Dados do Firestore são acessados via API routes — sem Firebase SDK aqui
  import { auth, db } from "~/lib/firebase";
  import {
    signInWithEmailAndPassword,
    signOut,
    onAuthStateChanged,
  } from "firebase/auth";
  import {
    doc,
    updateDoc,
    deleteDoc,
    getDoc,
    setDoc,
    collection,
    query,
    where,
    orderBy,
    limit,
    startAfter,
    getDocs,
    Timestamp,
    type QueryDocumentSnapshot,
    type DocumentData,
  } from "firebase/firestore";

  interface GrupoAdmin {
    id: string;
    nome: string;
    descricao: string;
    categoria: string;
    tipo: "grupo" | "canal";
    link: string;
    email?: string;
    foto?: string;
    membros?: number;
    destaque?: boolean;
    criadoEm?: string | null;
  }

  // Elementos
  const telaLogin = document.getElementById("tela-login")!;
  const painel = document.getElementById("painel")!;
  const inputEmail = document.getElementById("input-email") as HTMLInputElement;
  const inputSenha = document.getElementById("input-senha") as HTMLInputElement;
  const btnLogin = document.getElementById("btn-login") as HTMLButtonElement;
  const erroLogin = document.getElementById("erro-login")!;
  const toggleAds = document.getElementById("toggle-ads") as HTMLInputElement;
  const btnSair = document.getElementById("btn-sair")!;
  const labelUsuario = document.getElementById("label-usuario")!;
  const loadingEl = document.getElementById("loading-grupos")!;
  const listaEl = document.getElementById("lista-grupos")!;
  const listaPesquisas = document.getElementById("lista-pesquisas")!;
  const pesquisasTbody = document.getElementById("pesquisas-tbody")!;
  const pesquisasCards = document.getElementById("pesquisas-cards")!;
  const pesquisasFiltroAviso = document.getElementById(
    "pesquisas-filtro-aviso"
  ) as HTMLElement;
  const inputPesqDataDe = document.getElementById(
    "pesq-data-de"
  ) as HTMLInputElement;
  const inputPesqDataAte = document.getElementById(
    "pesq-data-ate"
  ) as HTMLInputElement;
  const inputPesqTermo = document.getElementById(
    "pesq-termo"
  ) as HTMLInputElement;
  const btnPesqFiltrar = document.getElementById(
    "pesq-btn-filtrar"
  ) as HTMLButtonElement;
  const btnPesqLimpar = document.getElementById(
    "pesq-btn-limpar"
  ) as HTMLButtonElement;
  const btnPesquisasPrev = document.getElementById(
    "pesquisas-prev"
  ) as HTMLButtonElement;
  const btnPesquisasNext = document.getElementById(
    "pesquisas-next"
  ) as HTMLButtonElement;
  const pesquisasPageMeta = document.getElementById("pesquisas-page-meta")!;
  const vazioPesquisas = document.getElementById("vazio-pesquisas")!;
  const vazioEl = document.getElementById("lista-vazia")!;
  const badgeEl = document.getElementById("badge-pendente")!;
  const abaBtns = Array.from(
    document.querySelectorAll<HTMLElement>(".aba-btn")
  );
  const tpl = document.getElementById("tpl-card") as HTMLTemplateElement;

  let abaAtual = "pendente";

  const TZ_BRASILIA = "America/Sao_Paulo";

  /** Tabela compacta: data curta + hora */
  function formatarDataHoraCompacta(
    criadoEm: { toDate?: () => Date } | undefined
  ) {
    const dt = criadoEm?.toDate?.();
    if (!dt) {
      return { data: "—", hora: "—" };
    }
    const data = new Intl.DateTimeFormat("pt-BR", {
      timeZone: TZ_BRASILIA,
      day: "2-digit",
      month: "2-digit",
      year: "numeric",
    }).format(dt);
    const hora = new Intl.DateTimeFormat("pt-BR", {
      timeZone: TZ_BRASILIA,
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false,
    }).format(dt);
    return { data, hora };
  }

  const PESQ_PAGE_SIZE = 30;
  /** Máximo de docs com filtros (1 leitura em lote — rápido no celular). */
  const PESQ_FILTER_MAX = 800;

  let pesqMetaLinhaExtra = "";

  type PesqCachedPage = {
    rows: Record<string, unknown>[];
    lastSnap: QueryDocumentSnapshot<DocumentData>;
  };

  let pesqMode: "firestore" | "memory" = "firestore";
  let pesqCachedPages: PesqCachedPage[] = [];
  let pesqPageIdx = 0;
  let pesqLastFetchedPageHasMore = false;
  let pesqMemoryAll: Record<string, unknown>[] = [];
  let pesqMemoryPageIdx = 0;

  function pesquisasResetEstado() {
    pesqMode = "firestore";
    pesqCachedPages = [];
    pesqPageIdx = 0;
    pesqLastFetchedPageHasMore = false;
    pesqMemoryAll = [];
    pesqMemoryPageIdx = 0;
    pesqMetaLinhaExtra = "";
    pesquisasTbody.innerHTML = "";
    pesquisasCards.innerHTML = "";
    pesquisasFiltroAviso.classList.add("hidden");
    pesquisasFiltroAviso.textContent = "";
  }

  function pesquisasTemFiltrosNosInputs(): boolean {
    return !!(
      inputPesqDataDe.value ||
      inputPesqDataAte.value ||
      inputPesqTermo.value.trim()
    );
  }

  function parseDateLocalStart(iso: string): Date | null {
    if (!/^\d{4}-\d{2}-\d{2}$/.test(iso)) return null;
    const [y, m, d] = iso.split("-").map(Number);
    return new Date(y, m - 1, d, 0, 0, 0, 0);
  }

  function parseDateLocalEnd(iso: string): Date | null {
    if (!/^\d{4}-\d{2}-\d{2}$/.test(iso)) return null;
    const [y, m, d] = iso.split("-").map(Number);
    return new Date(y, m - 1, d, 23, 59, 59, 999);
  }

  function filtrarLinhasPorTermo(
    rows: Record<string, unknown>[],
    termo: string
  ): Record<string, unknown>[] {
    const t = termo.trim().toLowerCase();
    if (!t) return rows;
    return rows.filter((r) => {
      const a = String(r.termo ?? "").toLowerCase();
      const b = String(r.termoNormalizado ?? "").toLowerCase();
      return a.includes(t) || b.includes(t);
    });
  }

  function renderPesquisasResultados(rows: Record<string, unknown>[]) {
    pesquisasTbody.innerHTML = "";
    pesquisasCards.innerHTML = "";

    rows.forEach((d, i) => {
      const { data: dStr, hora: hStr } = formatarDataHoraCompacta(
        d.criadoEm as { toDate?: () => Date } | undefined
      );
      const termo = String(d.termo ?? "");
      const n = Number(d.resultados);
      const nTxt = Number.isFinite(n) ? String(n) : "—";

      const li = document.createElement("li");
      li.className =
        "rounded-2xl border border-gray-200/90 bg-white p-3.5 shadow-sm ring-1 ring-black/[0.03] transition-transform active:scale-[0.99]";
      const pTermo = document.createElement("p");
      pTermo.className =
        "text-[15px] font-semibold leading-snug text-gray-900 break-words";
      pTermo.textContent = termo;
      const foot = document.createElement("div");
      foot.className =
        "mt-2.5 flex flex-wrap items-center justify-between gap-2 text-xs text-gray-500";
      const meta = document.createElement("span");
      meta.className = "font-mono tabular-nums";
      meta.textContent = `${dStr} · ${hStr}`;
      const badge = document.createElement("span");
      badge.className =
        "inline-flex min-w-[2rem] items-center justify-center rounded-lg bg-emerald-50 px-2 py-0.5 text-[11px] font-bold text-emerald-800 tabular-nums";
      badge.textContent = nTxt;
      foot.append(meta, badge);
      li.append(pTermo, foot);
      pesquisasCards.appendChild(li);

      const tr = document.createElement("tr");
      tr.className =
        (i % 2 === 0 ? "bg-white" : "bg-slate-50/60") +
        " transition-colors hover:bg-emerald-50/50";
      const td0 = document.createElement("td");
      td0.className =
        "px-4 py-2.5 font-mono text-xs text-gray-600 whitespace-nowrap align-middle";
      td0.textContent = dStr;
      const td1 = document.createElement("td");
      td1.className =
        "px-4 py-2.5 font-mono text-xs text-gray-600 whitespace-nowrap align-middle";
      td1.textContent = hStr;
      const td2 = document.createElement("td");
      td2.className =
        "px-4 py-2.5 align-middle text-gray-800 max-w-[220px] lg:max-w-xl truncate";
      td2.title = termo;
      td2.textContent = termo;
      const td3 = document.createElement("td");
      td3.className =
        "px-4 py-2.5 text-center text-sm font-semibold tabular-nums text-emerald-800 align-middle";
      td3.textContent = nTxt;
      tr.append(td0, td1, td2, td3);
      pesquisasTbody.appendChild(tr);
    });
  }

  function updatePesquisasPagerUI() {
    if (pesqMode === "memory") {
      const total = pesqMemoryAll.length;
      const pages = Math.max(1, Math.ceil(total / PESQ_PAGE_SIZE));
      const start = pesqMemoryPageIdx * PESQ_PAGE_SIZE + 1;
      const end = Math.min((pesqMemoryPageIdx + 1) * PESQ_PAGE_SIZE, total);
      btnPesquisasPrev.disabled = pesqMemoryPageIdx <= 0;
      btnPesquisasNext.disabled = pesqMemoryPageIdx >= pages - 1;
      const tailMem =
        pesqMetaLinhaExtra ||
        (!pesquisasTemFiltrosNosInputs() ? " · modo sem índice" : "");
      pesquisasPageMeta.textContent =
        total > 0
          ? `Página ${pesqMemoryPageIdx + 1} / ${pages} · ${start}–${end} de ${total}${tailMem}`
          : "";
      return;
    }

    const nCached = pesqCachedPages.length;
    const hasNext =
      pesqPageIdx < nCached - 1 ||
      (pesqPageIdx === nCached - 1 && pesqLastFetchedPageHasMore);
    btnPesquisasPrev.disabled = pesqPageIdx <= 0;
    btnPesquisasNext.disabled = !hasNext;
    const mostrando = pesqCachedPages[pesqPageIdx]?.rows.length ?? 0;
    pesquisasPageMeta.textContent =
      nCached > 0
        ? `Página ${pesqPageIdx + 1} · ${mostrando} registro(s) nesta página` +
          (pesqLastFetchedPageHasMore && pesqPageIdx === nCached - 1
            ? " · há mais em “Próxima”"
            : "") +
          pesqMetaLinhaExtra
        : "";
  }

  function pesquisasRenderMemoryPage() {
    const start = pesqMemoryPageIdx * PESQ_PAGE_SIZE;
    const slice = pesqMemoryAll.slice(start, start + PESQ_PAGE_SIZE);
    renderPesquisasResultados(slice);
    updatePesquisasPagerUI();
  }

  async function pesquisasFetchNextFirestorePage(): Promise<boolean> {
    const col = collection(db, "pesquisas_grupos");
    const lastPage = pesqCachedPages[pesqCachedPages.length - 1];
    const q = lastPage
      ? query(
          col,
          orderBy("criadoEm", "desc"),
          startAfter(lastPage.lastSnap),
          limit(PESQ_PAGE_SIZE + 1)
        )
      : query(
          col,
          orderBy("criadoEm", "desc"),
          limit(PESQ_PAGE_SIZE + 1)
        );
    const snap = await getDocs(q);
    if (snap.empty) {
      pesqLastFetchedPageHasMore = false;
      return false;
    }
    const docs = snap.docs;
    const hasMore = docs.length > PESQ_PAGE_SIZE;
    const pageDocs = hasMore ? docs.slice(0, PESQ_PAGE_SIZE) : docs;
    pesqLastFetchedPageHasMore = hasMore;
    const lastSnap = pageDocs[pageDocs.length - 1];
    pesqCachedPages.push({
      rows: pageDocs.map((d) => d.data() as Record<string, unknown>),
      lastSnap,
    });
    return true;
  }

  function normalizarOrdemDatas() {
    const a = inputPesqDataDe.value;
    const b = inputPesqDataAte.value;
    if (!a || !b) return;
    const da = parseDateLocalStart(a);
    const db = parseDateLocalStart(b);
    if (da && db && da > db) {
      inputPesqDataDe.value = b;
      inputPesqDataAte.value = a;
    }
  }

  async function pesquisasCarregarFiltradoFallbackClient(
    startD: Date | null,
    endD: Date | null,
    termo: string,
    msgEl: HTMLElement
  ): Promise<boolean> {
    const snap = await getDocs(
      query(collection(db, "pesquisas_grupos"), limit(2000))
    );
    let rows = snap.docs
      .filter((docSnap) => docSnap.data().criadoEm)
      .map((docSnap) => docSnap.data() as Record<string, unknown>)
      .sort(
        (a, b) =>
          ((b.criadoEm as { toMillis?: () => number })?.toMillis?.() ?? 0) -
          ((a.criadoEm as { toMillis?: () => number })?.toMillis?.() ?? 0)
      );
    const tMs = (x: Record<string, unknown>) =>
      (x.criadoEm as { toMillis?: () => number })?.toMillis?.() ?? 0;
    if (startD) {
      const ms = Timestamp.fromDate(startD).toMillis();
      rows = rows.filter((r) => tMs(r) >= ms);
    }
    if (endD) {
      const ms = Timestamp.fromDate(endD).toMillis();
      rows = rows.filter((r) => tMs(r) <= ms);
    }
    rows = filtrarLinhasPorTermo(rows, termo);
    pesqMode = "memory";
    pesqMemoryAll = rows;
    pesqMemoryPageIdx = 0;
    pesqMetaLinhaExtra = " · filtrado no aparelho (≤2000)";
    pesquisasFiltroAviso.textContent =
      "Sem índice no Firestore para este filtro: carregamos até 2000 registros e filtramos no dispositivo.";
    pesquisasFiltroAviso.classList.remove("hidden");
    if (rows.length === 0) {
      msgEl.textContent = "Nenhum resultado para esses filtros.";
      return false;
    }
    pesquisasRenderMemoryPage();
    return true;
  }

  async function pesquisasCarregarFiltrado(msgEl: HTMLElement): Promise<void> {
    normalizarOrdemDatas();
    const dateDe = inputPesqDataDe.value;
    const dateAte = inputPesqDataAte.value;
    const termo = inputPesqTermo.value;
    const startD = dateDe ? parseDateLocalStart(dateDe) : null;
    const endD = dateAte ? parseDateLocalEnd(dateAte) : null;

    const col = collection(db, "pesquisas_grupos");
    const constraints = [];
    if (startD) {
      constraints.push(where("criadoEm", ">=", Timestamp.fromDate(startD)));
    }
    if (endD) {
      constraints.push(where("criadoEm", "<=", Timestamp.fromDate(endD)));
    }
    constraints.push(orderBy("criadoEm", "desc"));
    constraints.push(limit(PESQ_FILTER_MAX));

    pesqMode = "memory";
    pesqMetaLinhaExtra = "";

    try {
      const snap = await getDocs(query(col, ...constraints));
      let rows = snap.docs.map((d) => d.data() as Record<string, unknown>);
      rows = filtrarLinhasPorTermo(rows, termo);

      const avisos: string[] = [];
      if (!dateDe && !dateAte && termo.trim()) {
        avisos.push(
          "Sem datas: o termo é buscado só entre os 800 registros mais recentes."
        );
      }
      if (snap.docs.length >= PESQ_FILTER_MAX) {
        avisos.push(
          `Limite de ${PESQ_FILTER_MAX} registros — aperte o período se precisar refinar.`
        );
        pesqMetaLinhaExtra = ` · até ${PESQ_FILTER_MAX} registros`;
      }
      if (avisos.length) {
        pesquisasFiltroAviso.textContent = avisos.join(" ");
        pesquisasFiltroAviso.classList.remove("hidden");
      }

      pesqMemoryAll = rows;
      pesqMemoryPageIdx = 0;

      if (rows.length === 0) {
        msgEl.textContent = "Nenhum resultado para esses filtros.";
        vazioPesquisas.classList.remove("hidden");
        return;
      }
      pesquisasRenderMemoryPage();
      listaPesquisas.classList.remove("hidden");
    } catch (err: unknown) {
      const c = firebaseErrCode(err);
      console.warn("[pesquisas filtro]", c, err);
      if (c === "failed-precondition" || c === "unimplemented") {
        const ok = await pesquisasCarregarFiltradoFallbackClient(
          startD,
          endD,
          termo,
          msgEl
        );
        if (ok) listaPesquisas.classList.remove("hidden");
        else vazioPesquisas.classList.remove("hidden");
      } else {
        throw err;
      }
    }
  }

  async function pesquisasCarregarLivre(msgEl: HTMLElement): Promise<void> {
    pesqMode = "firestore";
    try {
      const ok = await pesquisasFetchNextFirestorePage();
      const primeira = pesqCachedPages[0];
      if (!ok || !primeira || primeira.rows.length === 0) {
        msgEl.textContent = "Nenhuma pesquisa registrada ainda";
        vazioPesquisas.classList.remove("hidden");
      } else {
        pesqPageIdx = 0;
        renderPesquisasResultados(primeira.rows);
        updatePesquisasPagerUI();
        listaPesquisas.classList.remove("hidden");
      }
    } catch (firstErr: unknown) {
      const c = firebaseErrCode(firstErr);
      console.warn("[admin pesquisas] orderBy(criadoEm):", c, firstErr);
      if (c === "failed-precondition" || c === "unimplemented") {
        pesqMode = "memory";
        const snap2 = await getDocs(
          query(collection(db, "pesquisas_grupos"), limit(2000))
        );
        pesqMemoryAll = snap2.docs
          .filter((docSnap) => docSnap.data().criadoEm)
          .sort(
            (a, b) =>
              (b.data().criadoEm?.toMillis?.() ?? 0) -
              (a.data().criadoEm?.toMillis?.() ?? 0)
          )
          .map((docSnap) => docSnap.data() as Record<string, unknown>);
        pesqMemoryPageIdx = 0;
        if (pesqMemoryAll.length === 0) {
          msgEl.textContent = "Nenhuma pesquisa registrada ainda";
          vazioPesquisas.classList.remove("hidden");
        } else {
          pesquisasRenderMemoryPage();
          listaPesquisas.classList.remove("hidden");
        }
      } else {
        throw firstErr;
      }
    }
  }

  function firebaseErrCode(e: unknown): string {
    if (e !== null && typeof e === "object" && "code" in e) {
      const c = (e as { code?: string }).code;
      return typeof c === "string" ? c : "";
    }
    return "";
  }

  async function pesquisasNavegar(dir: "prev" | "next") {
    if (pesqMode === "memory") {
      if (dir === "prev" && pesqMemoryPageIdx > 0) {
        pesqMemoryPageIdx--;
        pesquisasRenderMemoryPage();
      } else if (dir === "next") {
        const pages = Math.max(
          1,
          Math.ceil(pesqMemoryAll.length / PESQ_PAGE_SIZE)
        );
        if (pesqMemoryPageIdx < pages - 1) {
          pesqMemoryPageIdx++;
          pesquisasRenderMemoryPage();
        }
      }
      return;
    }

    if (dir === "prev") {
      if (pesqPageIdx > 0) {
        pesqPageIdx--;
        renderPesquisasResultados(pesqCachedPages[pesqPageIdx].rows);
        updatePesquisasPagerUI();
      }
      return;
    }

    const podeIr =
      pesqPageIdx < pesqCachedPages.length - 1 ||
      (pesqPageIdx === pesqCachedPages.length - 1 && pesqLastFetchedPageHasMore);
    if (!podeIr) return;

    if (pesqPageIdx < pesqCachedPages.length - 1) {
      pesqPageIdx++;
      renderPesquisasResultados(pesqCachedPages[pesqPageIdx].rows);
      updatePesquisasPagerUI();
      return;
    }

    const u = auth.currentUser;
    if (!u) return;
    loadingEl.classList.remove("hidden");
    btnPesquisasNext.disabled = true;
    try {
      await u.getIdToken();
      const antes = pesqCachedPages.length;
      await pesquisasFetchNextFirestorePage();
      if (pesqCachedPages.length > antes) {
        pesqPageIdx = pesqCachedPages.length - 1;
        renderPesquisasResultados(pesqCachedPages[pesqPageIdx].rows);
      }
    } catch (e) {
      console.error(e);
    } finally {
      loadingEl.classList.add("hidden");
      updatePesquisasPagerUI();
    }
  }

  btnPesquisasPrev.addEventListener("click", () => {
    void pesquisasNavegar("prev");
  });
  btnPesquisasNext.addEventListener("click", () => {
    void pesquisasNavegar("next");
  });

  btnPesqFiltrar.addEventListener("click", () => {
    void carregarPesquisas();
  });
  btnPesqLimpar.addEventListener("click", () => {
    inputPesqDataDe.value = "";
    inputPesqDataAte.value = "";
    inputPesqTermo.value = "";
    void carregarPesquisas();
  });

  inputPesqTermo.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Enter") {
      e.preventDefault();
      void carregarPesquisas();
    }
  });

  // Auth — monitora estado de login
  onAuthStateChanged(auth, async (user) => {
    if (user) {
      telaLogin.classList.add("hidden");
      painel.classList.remove("hidden");
      labelUsuario.textContent = user.email;
      carregarGrupos(abaAtual);
      atualizarBadge();

      // Carregar state do ADS
      try {
        const adsRef = await getDoc(doc(db, "configs", "ads"));
        if (adsRef.exists()) {
          toggleAds.checked = adsRef.data().ativo !== false;
        } else {
          await setDoc(doc(db, "configs", "ads"), { ativo: true });
          toggleAds.checked = true;
        }
      } catch (e) {
        console.error("Falha ao carregar estado do ADS", e);
      }
    } else {
      telaLogin.classList.remove("hidden");
      painel.classList.add("hidden");
    }
  });

  btnLogin.addEventListener("click", async () => {
    erroLogin.classList.add("hidden");
    btnLogin.disabled = true;
    btnLogin.textContent = "Entrando...";
    try {
      await signInWithEmailAndPassword(
        auth,
        inputEmail.value.trim(),
        inputSenha.value
      );
    } catch {
      erroLogin.textContent = "E-mail ou senha incorretos.";
      erroLogin.classList.remove("hidden");
    } finally {
      btnLogin.disabled = false;
      btnLogin.textContent = "Entrar";
    }
  });

  [inputEmail, inputSenha].forEach((el) =>
    el.addEventListener(
      "keydown",
      (e: KeyboardEvent) => e.key === "Enter" && btnLogin.click()
    )
  );

  btnSair.addEventListener("click", () => signOut(auth));

  // Toggle ADS Event
  toggleAds.addEventListener("change", async (e) => {
    const isChecked = (e.target as HTMLInputElement).checked;
    try {
      await updateDoc(doc(db, "configs", "ads"), { ativo: isChecked });
      alert(isChecked ? "🎯 Anúncios ATIVADOS!" : "⏸️ Anúncios PAUSADOS!");
    } catch (err) {
      alert("Erro ao salvar config do ADS.");
      (e.target as HTMLInputElement).checked = !isChecked; // reverte mudança visual
    }
  });

  // Abas
  abaBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      abaAtual = btn.dataset.aba ?? "pendente";
      abaBtns.forEach((b) => {
        b.classList.remove("border-yellow-300", "text-gray-800");
        b.classList.add("border-transparent", "text-gray-400");
      });
      btn.classList.add("border-yellow-300", "text-gray-800");
      btn.classList.remove("border-transparent", "text-gray-400");
      if (abaAtual === "pesquisas") {
        carregarPesquisas();
      } else {
        carregarGrupos(abaAtual);
      }
    });
  });

  async function atualizarBadge() {
    try {
      const res = await fetch("/api/getGrupos.json?status=pendente");
      if (!res.ok) return;
      const grupos = await res.json();
      if (Array.isArray(grupos)) {
        badgeEl.textContent = grupos.length > 0 ? String(grupos.length) : "";
      }
    } catch (e) {
      console.error("Erro ao atualizar badge:", e);
    }
  }

  async function carregarPesquisas() {
    loadingEl.classList.remove("hidden");
    listaEl.classList.add("hidden");
    vazioEl.classList.add("hidden");
    listaPesquisas.classList.add("hidden");
    vazioPesquisas.classList.add("hidden");
    pesquisasResetEstado();
    btnPesquisasPrev.disabled = true;
    btnPesquisasNext.disabled = true;
    pesquisasPageMeta.textContent = "";

    const msgEl = vazioPesquisas.querySelector(".msg")!;
    const errDetail = vazioPesquisas.querySelector(
      ".err-detail"
    ) as HTMLElement;
    const hint = vazioPesquisas.querySelector(".hint") as HTMLElement;
    errDetail.classList.add("hidden");
    errDetail.textContent = "";
    hint.classList.remove("hidden");

    const user = auth.currentUser;
    if (!user) {
      msgEl.textContent = "Faça login novamente para ver as pesquisas.";
      vazioPesquisas.classList.remove("hidden");
      loadingEl.classList.add("hidden");
      return;
    }

    try {
      await user.getIdToken();
    } catch {
      msgEl.textContent = "Não foi possível renovar a sessão.";
      vazioPesquisas.classList.remove("hidden");
      loadingEl.classList.add("hidden");
      return;
    }

    try {
      if (pesquisasTemFiltrosNosInputs()) {
        await pesquisasCarregarFiltrado(msgEl);
      } else {
        await pesquisasCarregarLivre(msgEl);
      }
    } catch (e) {
      console.error(e);
      const code = firebaseErrCode(e);
      msgEl.textContent = "Erro ao carregar pesquisas";
      errDetail.textContent =
        code === "permission-denied"
          ? "permission-denied: usuário sem permissão de leitura em pesquisas_grupos. Publique o firestore.rules do projeto (allow list, get se auth != null). Se o App Check estiver obrigatório no Firestore, configure no app web."
          : code === "failed-precondition"
            ? "failed-precondition: índice do Firestore. O painel tentou modo alternativo; se persistir, crie o índice sugerido no link do console (F12 → aba Console)."
            : `${code || "erro"}: ${e instanceof Error ? e.message : String(e)}`;
      errDetail.classList.remove("hidden");
      vazioPesquisas.classList.remove("hidden");
    } finally {
      loadingEl.classList.add("hidden");
    }
  }

  async function carregarGrupos(status: string) {
    loadingEl.classList.remove("hidden");
    listaEl.classList.add("hidden");
    vazioEl.classList.add("hidden");
    listaPesquisas.classList.add("hidden");
    vazioPesquisas.classList.add("hidden");
    listaEl.innerHTML = "";

    try {
      const res = await fetch(`/api/getGrupos.json?status=${status}`);
      if (!res.ok) throw new Error("Erro na API");
      const grupos = await res.json();
      if (Array.isArray(grupos)) {
        if (grupos.length === 0) {
          vazioEl.classList.remove("hidden");
        } else {
          grupos.forEach((g: GrupoAdmin) => renderCard(g, status));
          listaEl.classList.remove("hidden");
        }
      } else {
        throw new Error("Formato de dados inválido");
      }
    } catch (e) {
      console.error(e);
      vazioEl.querySelector("p:last-child")!.textContent = "Erro ao carregar.";
      vazioEl.classList.remove("hidden");
    } finally {
      loadingEl.classList.add("hidden");
    }
  }

  function renderCard(grupo: GrupoAdmin, status: string) {
    const clone = tpl.content.cloneNode(true) as DocumentFragment;
    const avatarUrl =
      grupo.foto ??
      `https://ui-avatars.com/api/?name=${encodeURIComponent(
        grupo.nome?.slice(0, 2) ?? "G"
      )}&background=${
        grupo.tipo === "canal" ? "25D366" : "128C7E"
      }&color=fff&size=128&bold=true&rounded=true`;

    (clone.querySelector(".c-foto") as HTMLImageElement).src = avatarUrl;
    (clone.querySelector(".c-foto") as HTMLImageElement).alt = grupo.nome;
    clone.querySelector(".c-nome")!.textContent = grupo.nome;
    clone.querySelector(".c-desc")!.textContent = grupo.descricao;
    clone.querySelector(".c-cat")!.textContent = grupo.categoria;
    (clone.querySelector(".c-link") as HTMLAnchorElement).href = grupo.link;

    const tipoBadge = clone.querySelector(".c-tipo")!;
    if (grupo.tipo === "canal") {
      tipoBadge.textContent = "Canal";
      tipoBadge.classList.add("bg-green-100", "text-green-700");
    } else {
      tipoBadge.textContent = "Grupo";
      tipoBadge.classList.add("bg-teal-100", "text-teal-700");
    }

    // Borda por status
    const card = clone.querySelector(".card-grupo")!;
    if (status === "aprovado") card.classList.add("border-green-400");
    else if (status === "rejeitado") card.classList.add("border-red-300");
    else card.classList.add("border-yellow-300");

    const btnAprovar = clone.querySelector(".c-aprovar") as HTMLButtonElement;
    const btnRejeitar = clone.querySelector(".c-rejeitar") as HTMLButtonElement;
    const btnExcluir = clone.querySelector(".c-excluir") as HTMLButtonElement;
    const btnDestaque = clone.querySelector(".c-destaque") as HTMLButtonElement;

    if (grupo.destaque) {
      btnDestaque.classList.add("text-yellow-500");
      btnDestaque.classList.remove("text-gray-300");
      card.classList.add("bg-yellow-50/30", "border-yellow-200");
    }

    if (status === "pendente") {
      btnAprovar.classList.remove("hidden");
      btnRejeitar.classList.remove("hidden");
    } else if (status === "aprovado") {
      btnRejeitar.classList.remove("hidden");
    } else if (status === "rejeitado") {
      btnAprovar.classList.remove("hidden");
    }

    btnAprovar.onclick = () => mudarStatus(grupo, "aprovado");
    btnRejeitar.onclick = () => mudarStatus(grupo, "rejeitado");
    btnExcluir.onclick = () => deletarGrupo(grupo.id!);
    btnDestaque.onclick = () => toggleDestaque(grupo.id!, !!grupo.destaque);

    listaEl.appendChild(clone);
  }

  async function toggleDestaque(id: string, atual: boolean) {
    try {
      await updateDoc(doc(db, "grupos", id), { destaque: !atual });
      carregarGrupos(abaAtual);
    } catch (e) {
      alert("Erro: " + (e instanceof Error ? e.message : String(e)));
    }
  }

  async function deletarGrupo(id: string) {
    if (!confirm("Deseja excluir este grupo permanentemente?")) return;
    try {
      await deleteDoc(doc(db, "grupos", id));
      carregarGrupos(abaAtual);
      atualizarBadge();
    } catch (e) {
      alert("Erro ao excluir: " + (e instanceof Error ? e.message : String(e)));
    }
  }

  async function mudarStatus(
    grupo: GrupoAdmin,
    novoStatus: "aprovado" | "rejeitado"
  ) {
    try {
      const id = grupo.id;
      // 1. Atualizar o Firestore diretamente pelo navegador,
      // pois a permissão do Admin está na sessão do Firebase Auth do client
      await updateDoc(doc(db, "grupos", id), { status: novoStatus });

      // Atualiza UI de imediato
      carregarGrupos(abaAtual);
      atualizarBadge();

      // 2. Chama a API do servidor APENAS para enviar o e-mail de notificação
      const res = await fetch("/api/admin/mudar-status.json", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          id,
          status: novoStatus,
          email: grupo.email,
          nome: grupo.nome,
        }),
      });

      if (!res.ok) {
        console.warn(
          "Status atualizado no banco, mas houve falha ao enviar notificação de e-mail."
        );
      }
    } catch (e) {
      alert(
        "Erro ao atualizar status: " +
          (e instanceof Error ? e.message : String(e))
      );
    }
  }
</script>
