---
import { siteName } from "~/data/config";
import { menuNavigation, menuMisc, menuService, menuLegal } from "~/data/menus";
import NewsletterFooter from "./forms/NewsletterFooter.astro";
import IconLogo from "~/assets/images/icons/logo.svg";
import SocialMediaIcons from "./SocialMediaIcons.astro";
const year = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-100 text-gray-600">
	<div class="container py-20 lg:py-32">
		<div class="xl:grid xl:grid-cols-3 xl:gap-24">
			<div class="space-y-8">
				<a
					href="/"
					class="inline-block transition-transform hover:scale-105"
				>
					<div class="flex items-center gap-x-3">
						<div
							class="bg-gray-50 p-2 rounded-2xl shadow-sm border border-gray-100"
						>
							<IconLogo class="h-8" />
						</div>
						<span
							class="font-black text-2xl lg:text-3xl text-gray-950 tracking-tighter"
							>{siteName}
						</span>
					</div>
				</a>
				<p class="text-gray-500 font-medium max-w-xs leading-relaxed">
					O maior diretório de grupos e canais de WhatsApp do Brasil.
					Conectando pessoas e comunidades com segurança.
				</p>
				<div class="flex gap-x-6">
					<SocialMediaIcons />
				</div>
			</div>
			<div
				class="mt-16 grid grid-cols-2 lg:grid-cols-4 gap-8 xl:col-span-2 xl:mt-0"
			>
				{
					menuNavigation.items.length > 0 && (
						<div>
							<span class="text-xs font-black text-gray-900 uppercase tracking-[0.2em] mb-8 block font-outfit">
								{menuNavigation.prettyName}
							</span>
							<ul role="list" class="space-y-4">
								{menuNavigation.items.map((item) => (
									<li>
										<a
											href={item.url}
											class="text-sm font-bold transition hover:text-[#25D366]"
										>
											{item.name}
										</a>
									</li>
								))}
							</ul>
						</div>
					)
				}
				{
					menuService.items.length > 0 && (
						<div>
							<span class="text-xs font-black text-gray-900 uppercase tracking-[0.2em] mb-8 block font-outfit">
								{menuService.prettyName}
							</span>
							<ul role="list" class="space-y-4">
								{menuService.items.map((item) => (
									<li>
										<a
											href={item.url}
											class="text-sm font-bold transition hover:text-[#25D366]"
										>
											{item.name}
										</a>
									</li>
								))}
							</ul>
						</div>
					)
				}
				{
					menuMisc.items.length > 0 && (
						<div>
							<span class="text-xs font-black text-gray-900 uppercase tracking-[0.2em] mb-8 block font-outfit">
								{menuMisc.prettyName}
							</span>
							<ul role="list" class="space-y-4">
								{menuMisc.items.map((item) => (
									<li>
										<a
											href={item.url}
											class="text-sm font-bold transition hover:text-[#25D366]"
										>
											{item.name}
										</a>
									</li>
								))}
							</ul>
						</div>
					)
				}
				{
					menuLegal.items.length > 0 && (
						<div>
							<span class="text-xs font-black text-gray-900 uppercase tracking-[0.2em] mb-8 block font-outfit">
								{menuLegal.prettyName}
							</span>
							<ul role="list" class="space-y-4">
								{menuLegal.items.map((item) => (
									<li>
										<a
											href={item.url}
											class="text-sm font-bold transition hover:text-[#25D366]"
										>
											{item.name}
										</a>
									</li>
								))}
							</ul>
						</div>
					)
				}
			</div>
		</div>

		<div
			class="mt-20 border-t border-gray-100 pt-12 lg:flex lg:items-center lg:justify-between gap-12"
		>
			<div class="max-w-md mb-8 lg:mb-0">
				<span
					class="text-gray-950 font-black text-xl tracking-tighter font-outfit"
					>Assine nossa Newsletter</span
				>
				<p class="mt-2 text-sm text-gray-500 font-medium">
					As novidades, os melhores grupos e atualizações direto no
					seu e-mail de forma gratuita.
				</p>
			</div>
			<div class="flex-1 max-w-lg">
				<NewsletterFooter />
			</div>
		</div>

		<div
			class="mt-12 border-t border-gray-100 pt-12 flex flex-col md:flex-row md:items-center md:justify-between gap-6"
		>
			<p
				class="text-xs font-bold text-gray-400 tracking-widest uppercase"
			>
				&copy; {year}
				{siteName}. Todos os direitos reservados.
			</p>
			<div class="flex items-center gap-6">
				<span
					class="text-[10px] font-black text-gray-300 uppercase tracking-[0.2em]"
					>Feito com ❤️ para o Brasil</span
				>
			</div>
		</div>
	</div>
</footer>
