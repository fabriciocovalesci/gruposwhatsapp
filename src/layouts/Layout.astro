---
import "~/styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import { siteName, siteLang, themeColor } from "~/data/config";

const baseUrl = `${Astro.url.protocol}//${Astro.url.host}`;

interface Props {
	pageTitle?: string;
	title?: string;
	description?: string;
	keywords?: string;
	noindex?: boolean;
}

const defaultKeywords =
	"links de grupos de whatsapp, grupos de whatsapp 2025, entrar em grupos de whatsapp, link de canal whatsapp, grupos de amizade whatsapp, grupos de namoro whatsapp, grupos de figurinhas whatsapp, grupos de ganhar dinheiro whatsapp, grupos de divulgacao whatsapp, grupos de emprego whatsapp, whatsapp groups links";
const {
	pageTitle,
	title,
	description,
	keywords = defaultKeywords,
	noindex = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang={siteLang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content={themeColor} />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<link rel="canonical" href={Astro.url} />
		<meta
			name="robots"
			content={noindex ? "noindex, nofollow" : "index, follow"}
		/>
		<link rel="author" href="humans.txt" />

		<link rel="icon" type="image/png" href="/favicon.png" sizes="96x96" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="shortcut icon" href="/favicon.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon.png" />
		<meta name="apple-mobile-web-app-title" content={siteName} />

		<meta property="og:url" content={Astro.url} />
		<meta property="og:type" content="website" />
		<meta
			property="og:title"
			content={pageTitle || `${title} | ${siteName}`}
		/>
		<meta property="og:image" content={`${baseUrl}/images/og-image.jpg`} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:locale" content="pt_BR" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={Astro.url} />
		<meta
			name="twitter:title"
			content={pageTitle || `${title} | ${siteName}`}
		/>
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={`${baseUrl}/images/og-image.jpg`} />

		<!-- Google tag (gtag.js) -->
		<script
			async
			src="https://www.googletagmanager.com/gtag/js?id=G-XT3E53DJ2J"
		></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag("js", new Date());

			gtag("config", "G-XT3E53DJ2J");
		</script>

		{/* Ahrefs Analytics */}
		<script is:inline>
			var ahrefs_analytics_script = document.createElement("script");
			ahrefs_analytics_script.async = true;
			ahrefs_analytics_script.src =
				"https://analytics.ahrefs.com/analytics.js";
			ahrefs_analytics_script.setAttribute(
				"data-key",
				"7AcgAm+BSdmWD3IGfg+/3g"
			);
			document
				.getElementsByTagName("head")[0]
				.appendChild(ahrefs_analytics_script);
		</script>

		<title>{pageTitle}</title>

		<ClientRouter />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
		<script>
			document.addEventListener("astro:after-swap", () => {
				scrollTo({ top: history.state.scrollY, behavior: "instant" });
			});
		</script>

		{
			/* BACKGROUND SCRIPTS (POP-UNDERS / SOCIAL BARS) - FLOAT FROM BOTTOM */
		}
		<script
			is:inline
			src="https://pl28981421.profitablecpmratenetwork.com/d2/ee/fe/d2eefe65801032e60736ccd404ed350f.js"
		></script>
		<script
			is:inline
			src="https://pl28981422.profitablecpmratenetwork.com/7c/25/54/7c255470fd6b5fdd4bf9497258281d6d.js"
		></script>
	</body>
</html>
