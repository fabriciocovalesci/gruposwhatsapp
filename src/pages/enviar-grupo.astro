---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import { todasCategorias } from "~/lib/categorias";
---

<Layout
    pageTitle="Enviar Grupo de WhatsApp - GruposWhats.app"
    description="Cadastre seu link de grupo ou canal de WhatsApp gratuitamente no nosso diretório para conseguir novos membros."
>
    <Section class:list={"bg-gray-50 py-12 lg:py-24 min-h-[80vh]"}>
        <Container>
            <div
                class="max-w-2xl mx-auto bg-white rounded-[2.5rem] shadow-xl border border-gray-100 p-8 lg:p-12"
            >
                <div class="text-center mb-10">
                    <span
                        class="text-[#25D366] font-black uppercase tracking-[0.2em] text-xs mb-3 block"
                        >Divulgação Grátis</span
                    >
                    <h1
                        class="text-3xl lg:text-5xl font-black text-gray-950 mb-4 tracking-tighter"
                    >
                        Cadastrar Meu <span class="text-[#25D366]">Link</span>
                    </h1>
                    <p class="text-gray-500 font-medium">
                        Preencha os dados e receba novos membros em instantes.
                        Análise rápida e gratuita.
                    </p>
                </div>

                <div
                    id="form-success"
                    class="hidden mb-8 p-6 bg-green-50 text-green-800 rounded-3xl border border-green-200 animate-bounce"
                >
                    <div class="flex items-center gap-3">
                        <span class="text-2xl">🎉</span>
                        <div>
                            <strong class="block font-black">Sucesso!</strong>
                            Seu grupo foi enviado. Em breve estará no ar.
                        </div>
                    </div>
                </div>

                <div
                    id="form-error"
                    class="hidden mb-8 p-6 bg-red-50 text-red-800 rounded-3xl border border-red-200"
                >
                    <div class="flex items-center gap-3">
                        <span class="text-2xl">❌</span>
                        <div>
                            <strong class="block font-black">Opa!</strong>
                            Algo deu errado. Verifique os campos e tente de novo.
                        </div>
                    </div>
                </div>

                <form id="form-enviar-grupo" class="space-y-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <label
                                for="tipo"
                                class="block text-sm font-black text-gray-400 uppercase tracking-widest mb-2"
                                >O que você tem?</label
                            >
                            <select
                                id="tipo"
                                name="tipo"
                                required
                                class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl focus:ring-4 focus:ring-[#25D366]/20 font-bold text-gray-800 transition-all cursor-pointer"
                            >
                                <option value="grupo">Grupo do WhatsApp</option>
                                <option value="canal">Canal do WhatsApp</option>
                            </select>
                        </div>

                        <div>
                            <label
                                for="categoria"
                                class="block text-sm font-black text-gray-400 uppercase tracking-widest mb-2"
                                >Qual o assunto?</label
                            >
                            <select
                                id="categoria"
                                name="categoria"
                                required
                                class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl focus:ring-4 focus:ring-[#25D366]/20 font-bold text-gray-800 transition-all cursor-pointer"
                            >
                                <option value="" disabled selected
                                    >Escolha uma categoria...</option
                                >
                                {
                                    todasCategorias.map((cat) => (
                                        <option value={cat.slug}>
                                            {cat.label}
                                        </option>
                                    ))
                                }
                            </select>
                        </div>
                    </div>

                    <div>
                        <label
                            for="nome"
                            class="block text-sm font-black text-gray-400 uppercase tracking-widest mb-2"
                            >Nome <span class="text-red-500 font-black">*</span>
                        </label>
                        <input
                            type="text"
                            id="nome"
                            name="nome"
                            placeholder="Ex: Figurinhas Engraçadas 2024"
                            required
                            maxlength="60"
                            class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl focus:ring-4 focus:ring-[#25D366]/20 font-bold text-gray-800 placeholder:text-gray-300 transition-all"
                        />
                    </div>

                    <div>
                        <label
                            for="link"
                            class="block text-sm font-black text-gray-400 uppercase tracking-widest mb-2"
                            >Link de Convite <span
                                class="text-red-500 font-black">*</span
                            >
                        </label>
                        <input
                            type="url"
                            id="link"
                            name="link"
                            placeholder="https://chat.whatsapp.com/..."
                            required
                            class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl focus:ring-4 focus:ring-[#25D366]/20 font-bold text-gray-800 transition-all"
                        />
                    </div>

                    <div>
                        <label
                            for="descricao"
                            class="block text-sm font-black text-gray-400 uppercase tracking-widest mb-2"
                            >Sobre o Grupo <span class="text-red-500 font-black"
                                >*</span
                            >
                        </label>
                        <textarea
                            id="descricao"
                            name="descricao"
                            rows="4"
                            placeholder="Conte um pouco sobre o seu grupo e as regras..."
                            required
                            maxlength="250"
                            class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl focus:ring-4 focus:ring-[#25D366]/20 font-bold text-gray-800 transition-all resize-none"
                        ></textarea>
                    </div>

                    <div>
                        <label
                            for="email"
                            class="block text-sm font-black text-gray-400 uppercase tracking-widest mb-2"
                            >E-mail (Opcional)</label
                        >
                        <input
                            type="email"
                            id="email"
                            name="email"
                            placeholder="seu@contato.com"
                            class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl focus:ring-4 focus:ring-[#25D366]/20 font-bold text-gray-800 transition-all"
                        />
                    </div>

                    <div class="pt-4">
                        <button
                            type="submit"
                            id="btn-submit"
                            class="w-full py-5 px-8 bg-[#25D366] hover:bg-[#075E54] text-white font-black text-xl rounded-3xl shadow-xl hover:shadow-[#25D366]/40 transition-all active:scale-95 flex justify-center items-center gap-3 group"
                        >
                            <span id="btn-text">Cadastrar Meu Grupo</span>
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-6 w-6 group-hover:translate-x-1 transition-transform"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor font-black"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="3"
                                    d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                            </svg>
                        </button>
                    </div>

                    <p
                        class="text-[10px] font-black uppercase tracking-widest text-center text-gray-400 mt-6 leading-relaxed"
                    >
                        Ao cadastrar, você concorda com nossos termos. <br /> Proibido
                        conteúdo adulto, spam ou links ilegais.
                    </p>
                </form>
            </div>
        </Container>
    </Section>
</Layout>

<script>
    // Firebase logic to submit form client-side
    import { enviarGrupo } from "~/lib/grupos";

    const form = document.getElementById(
        "form-enviar-grupo"
    ) as HTMLFormElement;
    const btnSubmit = document.getElementById(
        "btn-submit"
    ) as HTMLButtonElement;
    const btnText = document.getElementById("btn-text")!;
    const msgSuccess = document.getElementById("form-success")!;
    const msgError = document.getElementById("form-error")!;

    if (form) {
        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            // Hide messages
            msgSuccess.classList.add("hidden");
            msgError.classList.add("hidden");

            // Loading state
            btnSubmit.disabled = true;
            btnText.innerHTML =
                '<svg class="animate-spin h-5 w-5 mr-3 text-white" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Enviando...';

            const formData = new FormData(form);

            const dados = {
                nome: formData.get("nome") as string,
                descricao: formData.get("descricao") as string,
                categoria: formData.get("categoria") as string,
                tipo: formData.get("tipo") as "grupo" | "canal",
                link: formData.get("link") as string,
                email: (formData.get("email") as string) || undefined,
            };

            try {
                await enviarGrupo(dados);
                form.reset();
                msgSuccess.classList.remove("hidden");

                // Optional: scroll to success message
                msgSuccess.scrollIntoView({
                    behavior: "smooth",
                    block: "center",
                });
            } catch (error) {
                console.error("Erro ao enviar grupo:", error);
                msgError.classList.remove("hidden");
            } finally {
                btnSubmit.disabled = false;
                btnText.textContent = "Enviar Grupo para Análise";
            }
        });
    }
</script>
