---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import { todasCategorias, getLabelCategoria } from "~/lib/grupos";
---

<Layout
    pageTitle="Enviar Grupo ou Canal - gruposwhatsapp.online"
    description="Divulgue seu grupo ou canal de WhatsApp gratuitamente e comece a receber novos membros agora mesmo."
>
    <Section class:list={"bg-gray-50 py-12 lg:py-20 min-h-screen"}>
        <Container>
            {/* Header */}
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h1
                    class="text-3xl lg:text-5xl font-black text-gray-950 mb-4 tracking-tighter"
                >
                    Enviar Grupo ou <span class="text-[#028b3a]">Canal</span>
                </h1>
                <p class="text-gray-500 font-medium italic">
                    "Divulgue seu link e receba novos membros em instantes."
                </p>
            </div>

            <div
                class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start justify-center"
            >
                {/* Lateral: Preview Card */}
                <div
                    id="preview-container"
                    class="lg:col-span-4 lg:sticky lg:top-24 order-1 z-0 hidden"
                >
                    <div
                        class="bg-white rounded-[2.5rem] shadow-2xl border border-gray-100 overflow-hidden relative"
                    >
                        <div class="p-6">
                            <div class="flex items-center gap-4 mb-5">
                                <div class="relative">
                                    <img
                                        id="preview-img"
                                        src="https://ui-avatars.com/api/?name=G&background=028b3a&color=fff&size=128&bold=true&rounded=true"
                                        alt="Preview Avatar"
                                        class="w-16 h-16 rounded-2xl object-cover bg-gray-50 shadow-sm"
                                    />
                                    <div
                                        class="absolute -bottom-1 -right-1 size-5 rounded-full border-2 border-white bg-[#028b3a] shadow-sm"
                                    >
                                    </div>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span
                                            class="text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded-lg bg-green-100 text-[#075E54]"
                                            id="preview-tipo">GRUPO</span
                                        >
                                        <span
                                            class="text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded-lg bg-gray-50 text-gray-700"
                                            id="preview-cat">CATEGORIA</span
                                        >
                                    </div>
                                    <h3
                                        class="font-black text-gray-950 text-lg truncate leading-tight"
                                        id="preview-nome"
                                    >
                                        Nome do Grupo
                                    </h3>
                                </div>
                            </div>
                            <p
                                class="text-gray-600 font-medium line-clamp-3 text-xs leading-relaxed mb-6"
                                id="preview-desc"
                            >
                                A descrição do seu grupo aparecerá aqui...
                            </p>
                            <div
                                class="w-full h-12 bg-[#028b3a] rounded-2xl flex items-center justify-center font-black text-white text-sm"
                            >
                                PARTICIPAR
                            </div>
                        </div>
                        <div
                            class="bg-gray-900 text-white text-[9px] font-black uppercase tracking-[0.2em] py-2 text-center"
                        >
                            Prévia do Card
                        </div>
                    </div>

                    <div
                        class="mt-8 bg-[#028b3a]/5 border border-[#028b3a]/20 p-6 rounded-3xl"
                    >
                        <div class="flex gap-3">
                            <span class="text-xl">🚀</span>
                            <div
                                class="text-xs text-[#075E54] font-bold leading-relaxed"
                            >
                                Dica: Grupos com nomes claros e descrições
                                detalhadas atraem mais membros engajados!
                            </div>
                        </div>
                    </div>
                </div>

                {/* Direita: Formulário Workflow */}
                <div
                    id="main-form-col"
                    class="lg:col-span-8 lg:col-start-3 order-2"
                >
                    {/* FEEDBACKS */}
                    <div
                        id="msg-erro"
                        class="hidden mb-6 p-6 bg-red-50 text-red-800 rounded-3xl border border-red-200 font-bold text-sm"
                    >
                    </div>

                    <div
                        id="msg-sucesso"
                        class="hidden text-center py-20 bg-white rounded-[3rem] shadow-xl border border-green-200"
                    >
                        <p class="text-7xl mb-6">✅</p>
                        <h2 class="text-3xl font-black text-gray-900 mb-2">
                            Sucesso!
                        </h2>
                        <p
                            class="text-gray-500 font-medium mb-10 max-w-sm mx-auto"
                        >
                            Seu grupo foi enviado para moderação e em breve
                            estará no ar.
                        </p>
                        <a
                            href="/"
                            class="inline-flex px-10 py-4 bg-[#028b3a] text-white rounded-2xl font-black hover:bg-gray-950 transition-all"
                            >Explorar Grupos</a
                        >
                    </div>

                    <div
                        id="form-container"
                        class="bg-white rounded-[2.5rem] shadow-xl border border-gray-100 p-8 lg:p-12"
                    >
                        {/* STEP 1: VALIDAR LINK */}
                        <div id="step-1" class="transition-all">
                            <h2 class="text-2xl font-black text-gray-950 mb-2">
                                Primeiro Passo
                            </h2>
                            <p
                                class="text-gray-500 font-medium mb-8 text-sm italic"
                            >
                                Insira o link para preenchermos os dados
                                automaticamente.
                            </p>

                            <div class="space-y-6">
                                <div>
                                    <label
                                        for="link-verify"
                                        class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-3"
                                        >Link do Grupo ou Canal</label
                                    >
                                    <input
                                        type="url"
                                        id="link-verify"
                                        placeholder="https://chat.whatsapp.com/..."
                                        class="w-full px-8 py-5 bg-gray-50 border-none rounded-2xl focus:ring-4 focus:ring-[#028b3a]/20 font-bold text-gray-800 transition-all text-lg"
                                    />
                                </div>

                                <button
                                    id="btn-verify"
                                    class="w-full py-5 bg-gray-950 text-white font-black text-xl rounded-3xl hover:bg-[#028b3a] transition-all active:scale-95 flex items-center justify-center gap-3"
                                >
                                    <span id="txt-verify">Validar Link</span>
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-6 w-6"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="3"
                                            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                    </svg>
                                </button>

                                <p
                                    class="text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest leading-relaxed"
                                >
                                    Segurança: Verificamos se o convite está
                                    ativo antes de continuar.
                                </p>
                            </div>
                        </div>

                        {/* STEP 2: COMPLETAR DADOS */}
                        <div
                            id="step-2"
                            class="hidden transition-all animate-in fade-in slide-in-from-right-4 duration-500"
                        >
                            <h2
                                class="text-2xl font-black text-gray-950 mb-6 font-Inter"
                            >
                                Quase lá! Complete os Dados
                            </h2>

                            <form id="form-final" class="space-y-8">
                                <input
                                    type="hidden"
                                    id="final-link"
                                    name="link"
                                />
                                <input
                                    type="hidden"
                                    id="final-foto"
                                    name="foto"
                                />

                                <div
                                    class="grid grid-cols-1 md:grid-cols-2 gap-8"
                                >
                                    <div>
                                        <label
                                            class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2"
                                            >Tipo de Link</label
                                        >
                                        <select
                                            name="tipo"
                                            id="final-tipo"
                                            class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl font-bold text-gray-800 cursor-pointer"
                                        >
                                            <option value="grupo">Grupo</option>
                                            <option value="canal">Canal</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label
                                            class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2"
                                            >Categoria</label
                                        >
                                        <select
                                            name="categoria"
                                            required
                                            id="final-cat"
                                            class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl font-bold text-gray-800 cursor-pointer"
                                        >
                                            <option value="" disabled selected
                                                >Escolha uma categoria...</option
                                            >
                                            {
                                                todasCategorias.map((c) => (
                                                    <option value={c.slug}>
                                                        {c.label}
                                                    </option>
                                                ))
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div>
                                    <label
                                        class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2"
                                        >Nome Exibido</label
                                    >
                                    <input
                                        type="text"
                                        name="nome"
                                        id="final-nome"
                                        required
                                        class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl font-bold text-gray-800"
                                    />
                                </div>

                                <div>
                                    <label
                                        class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2"
                                        >Descrição Curta</label
                                    >
                                    <textarea
                                        name="descricao"
                                        id="final-desc"
                                        rows="3"
                                        required
                                        placeholder="Ex: O melhor grupo para colecionadores de moedas!"
                                        class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl font-bold text-gray-800 resize-none"
                                    ></textarea>
                                </div>

                                <div
                                    class="bg-gray-50/50 p-4 rounded-[1.5rem] border border-gray-100"
                                >
                                    <label
                                        class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-3 italic"
                                        >Quais são as regras? (Toque para
                                        ativar)</label
                                    >
                                    <div class="flex flex-wrap gap-1.5 mb-5">
                                        {
                                            [
                                                "Proibido Adulto",
                                                "Sem Agressividade",
                                                "Sem Palavrões",
                                                "Sem Trava Zap",
                                                "Apenas +18",
                                                "Sem Links",
                                            ].map((regra) => (
                                                <label class="flex items-center gap-1.5 px-2.5 py-1.5 bg-white border border-gray-200 rounded-full cursor-pointer transition-all hover:border-[#028b3a] group has-[:checked]:bg-[#028b3a]/5 has-[:checked]:border-[#028b3a] shadow-sm">
                                                    <input
                                                        type="checkbox"
                                                        name="regras"
                                                        value={regra}
                                                        checked
                                                        class="size-3 rounded-full border-gray-300 text-[#028b3a] focus:ring-[#028b3a] transition-all"
                                                    />
                                                    <span class="text-[9px] font-black text-gray-500 uppercase tracking-tight group-hover:text-[#075E54]">
                                                        {regra}
                                                    </span>
                                                </label>
                                            ))
                                        }
                                    </div>

                                    <div class="space-y-2">
                                        <label
                                            class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1 italic"
                                            >Deseja adicionar mais regras
                                            personalizadas?</label
                                        >
                                        <textarea
                                            name="regras_extras"
                                            rows="2"
                                            placeholder="Escreva uma regra por linha..."
                                            class="w-full px-5 py-3 bg-white border border-gray-200 rounded-2xl text-[11px] font-bold text-gray-600 focus:ring-2 focus:ring-[#028b3a]/20 transition-all resize-none shadow-sm"
                                        ></textarea>
                                        <p
                                            class="text-[8px] text-gray-400 font-bold uppercase tracking-widest leading-tight"
                                        >
                                            Opcional: Você pode escrever as
                                            regras do seu grupo, uma por linha.
                                        </p>
                                    </div>
                                </div>

                                <div>
                                    <label
                                        class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2"
                                        >E-mail para Receber Avisos</label
                                    >
                                    <input
                                        type="email"
                                        name="email"
                                        placeholder="seu@email.com"
                                        class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl font-bold text-gray-800"
                                    />
                                </div>

                                <button
                                    type="submit"
                                    id="btn-enviar"
                                    class="w-full py-5 bg-[#028b3a] text-white font-black text-xl rounded-3xl shadow-xl hover:shadow-[#028b3a]/30 transition-all active:scale-95"
                                >
                                    Finalizar Cadastro
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </Container>
    </Section>
</Layout>

<script>
    import { enviarGrupo } from "~/lib/grupos";

    const step1 = document.getElementById("step-1")!;
    const step2 = document.getElementById("step-2")!;
    const btnVerify = document.getElementById(
        "btn-verify"
    ) as HTMLButtonElement;
    const txtVerify = document.getElementById("txt-verify")!;
    const linkInput = document.getElementById(
        "link-verify"
    ) as HTMLInputElement;
    const msgErro = document.getElementById("msg-erro")!;

    // Final form elements
    const formFinal = document.getElementById("form-final") as HTMLFormElement;
    const finalLink = document.getElementById("final-link") as HTMLInputElement;
    const finalFoto = document.getElementById("final-foto") as HTMLInputElement;
    const finalNome = document.getElementById("final-nome") as HTMLInputElement;
    const finalDesc = document.getElementById(
        "final-desc"
    ) as HTMLTextAreaElement;
    const finalTipo = document.getElementById(
        "final-tipo"
    ) as HTMLSelectElement;
    const finalCat = document.getElementById("final-cat") as HTMLSelectElement;

    // Preview elements
    const pNome = document.getElementById("preview-nome")!;
    const pDesc = document.getElementById("preview-desc")!;
    const pTipo = document.getElementById("preview-tipo")!;
    const pCat = document.getElementById("preview-cat")!;
    const pImg = document.getElementById("preview-img") as HTMLImageElement;

    // Webhook logic
    btnVerify.addEventListener("click", async () => {
        const link = linkInput.value.trim();
        const isGroup = link.startsWith("https://chat.whatsapp.com/");
        const isChannel =
            link.startsWith("https://whatsapp.com/channel/") ||
            link.startsWith("https://www.whatsapp.com/channel/");

        if (!isGroup && !isChannel) {
            msgErro.textContent =
                "Link inválido: Use um link válido do WhatsApp (Grupos ou Canais) no formato: https://chat.whatsapp.com/ ou https://whatsapp.com/channel/";
            msgErro.classList.remove("hidden");
            return;
        }

        msgErro.classList.add("hidden");
        btnVerify.disabled = true;
        txtVerify.textContent = "Analisando Link...";

        try {
            const res = await fetch(
                "https://n8n.qrlembrancasvivas.com.br/webhook/verify",
                {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        Authorization: "Basic YWRtaW5ncnVwb3M6YlFZVjhkMDkyWG1i",
                    },
                    body: JSON.stringify({ group: link }),
                }
            );

            if (!res.ok) throw new Error("Falha na comunicação.");

            const data = await res.json();

            if (data.success) {
                // Pre-fill Step 2
                finalLink.value = link;
                finalNome.value = data.groupName || "";
                finalFoto.value = data.groupImage || "";

                // Update Preview immediately
                pNome.textContent = data.groupName || "Nome do Grupo";
                if (data.groupImage) pImg.src = data.groupImage;

                // Move to step 2
                const previewCont =
                    document.getElementById("preview-container");
                const formCol = document.getElementById("main-form-col");
                previewCont?.classList.remove("hidden");
                formCol?.classList.remove("lg:col-start-3");

                step1.classList.add("hidden");
                step2.classList.remove("hidden");
            } else {
                msgErro.textContent =
                    data.error ||
                    "Link inválido. Verifique se o convite não expirou.";
                msgErro.classList.remove("hidden");
            }
        } catch (err) {
            msgErro.textContent =
                "Ops! Tivemos um problema técnico. Tente novamente.";
            msgErro.classList.remove("hidden");
        } finally {
            btnVerify.disabled = false;
            txtVerify.textContent = "Validar Link";
        }
    });

    // Real-time Preview logic
    [finalNome, finalDesc, finalTipo, finalCat].forEach((el) => {
        el.addEventListener("input", () => {
            pNome.textContent = finalNome.value || "Nome do Grupo";
            const desc = finalDesc.value || "A descrição aparecerá aqui...";
            pDesc.textContent = desc;
            pTipo.textContent = finalTipo.value.toUpperCase();
            pCat.textContent =
                finalCat.options[finalCat.selectedIndex]?.text.toUpperCase() ||
                "CATEGORIA";
        });
    });

    // Final Form Submission
    formFinal.addEventListener("submit", async (e) => {
        e.preventDefault();
        const btn = document.getElementById("btn-enviar") as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = "Publicando...";

        const formData = new FormData(formFinal);
        const regrasMarcadas = formData.getAll("regras") as string[];
        const regrasExtrasRaw = formData.get("regras_extras") as string;
        const regrasExtras = regrasExtrasRaw
            ? regrasExtrasRaw
                  .split("\n")
                  .map((r) => r.trim())
                  .filter((r) => r.length > 0)
            : [];
        const regras = [...regrasMarcadas, ...regrasExtras];

        const dados = {
            nome: formData.get("nome") as string,
            descricao: formData.get("descricao") as string,
            categoria: formData.get("categoria") as string,
            tipo: formData.get("tipo") as "grupo" | "canal",
            link: formData.get("link") as string,
            foto: formData.get("foto") as string,
            email: (formData.get("email") as string) || undefined,
            regras: regras,
        };

        try {
            await enviarGrupo(dados);
            const previewCont = document.getElementById("preview-container");
            const formCol = document.getElementById("main-form-col");
            previewCont?.classList.add("hidden");
            formCol?.classList.add("lg:col-start-3");

            document.getElementById("form-container")!.classList.add("hidden");
            document.getElementById("msg-sucesso")!.classList.remove("hidden");
            window.scrollTo({ top: 0, behavior: "smooth" });
        } catch (err) {
            msgErro.textContent = "Erro ao salvar seu grupo. Tente novamente.";
            msgErro.classList.remove("hidden");
            btn.disabled = false;
            btn.textContent = "Finalizar Cadastro";
        }
    });
</script>
