---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import { todasCategorias, getLabelCategoria, getGrupoById } from "~/lib/grupos";

const editId = Astro.url.searchParams.get("edit");
let editGrupo = null;
if (editId) {
    editGrupo = await getGrupoById(editId);
}
---

<Layout
    pageTitle={editGrupo
        ? `Editar ${editGrupo.nome} - gruposwhatsapp.online`
        : "Enviar Grupo ou Canal - gruposwhatsapp.online"}
    description="Divulgue seu grupo ou canal de WhatsApp gratuitamente e comece a receber novos membros agora mesmo."
>
    <Section class:list={"bg-gray-50 py-12 lg:py-20 min-h-screen"}>
        <Container>
            {/* Header */}
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h1
                    class="text-3xl lg:text-5xl font-black text-gray-950 mb-4 tracking-tighter"
                >
                    {editGrupo ? "Editar" : "Enviar"} Grupo ou <span
                        class="text-[#028b3a]">Canal</span
                    >
                </h1>
                <p class="text-gray-500 font-medium italic">
                    "Divulgue seu link e receba novos membros em instantes."
                </p>
            </div>

            <div
                class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start justify-center"
            >
                {/* Lateral: Preview Card */}
                <div
                    id="preview-container"
                    class:list={[
                        "lg:col-span-4 lg:sticky lg:top-24 order-1 z-0",
                        !editId && "hidden",
                    ]}
                >
                    <div
                        class="bg-white rounded-[2.5rem] shadow-2xl border border-gray-100 overflow-hidden relative"
                    >
                        <div class="p-6">
                            <div class="flex items-center gap-4 mb-5">
                                <div class="relative">
                                    <img
                                        id="preview-img"
                                        src={editGrupo?.foto ||
                                            "https://ui-avatars.com/api/?name=G&background=028b3a&color=fff&size=128&bold=true&rounded=true"}
                                        alt="Preview Avatar"
                                        class="w-16 h-16 rounded-2xl object-cover bg-gray-50 shadow-sm"
                                    />
                                    <div
                                        class="absolute -bottom-1 -right-1 size-5 rounded-full border-2 border-white bg-[#028b3a] shadow-sm"
                                    >
                                    </div>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span
                                            class="text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded-lg bg-green-100 text-[#075E54]"
                                            id="preview-tipo"
                                            >{
                                                editGrupo?.tipo?.toUpperCase() ||
                                                    "GRUPO"
                                            }
                                        </span>
                                        <span
                                            class="text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded-lg bg-gray-50 text-gray-700"
                                            id="preview-cat"
                                            >{
                                                getLabelCategoria(
                                                    editGrupo?.categoria || ""
                                                )?.toUpperCase() || "CATEGORIA"
                                            }
                                        </span>
                                    </div>
                                    <h3
                                        class="font-black text-gray-950 text-lg truncate leading-tight"
                                        id="preview-nome"
                                    >
                                        {editGrupo?.nome || "Nome do Grupo"}
                                    </h3>
                                </div>
                            </div>
                            <p
                                class="text-gray-600 font-medium line-clamp-3 text-xs leading-relaxed mb-6"
                                id="preview-desc"
                            >
                                {
                                    editGrupo?.descricao ||
                                        "A descrição do seu grupo aparecerá aqui..."
                                }
                            </p>
                            <div
                                class="w-full h-12 bg-[#028b3a] rounded-2xl flex items-center justify-center font-black text-white text-sm"
                            >
                                PARTICIPAR
                            </div>
                        </div>
                        <div
                            class="bg-gray-900 text-white text-[9px] font-black uppercase tracking-[0.2em] py-2 text-center"
                        >
                            Prévia do Card
                        </div>
                    </div>

                    <div
                        class="mt-8 bg-[#028b3a]/5 border border-[#028b3a]/20 p-6 rounded-3xl"
                    >
                        <div class="flex gap-3">
                            <span class="text-xl">🚀</span>
                            <div
                                class="text-xs text-[#075E54] font-bold leading-relaxed"
                            >
                                Dica: Grupos com nomes claros e descrições
                                detalhadas atraem mais membros engajados!
                            </div>
                        </div>
                    </div>
                </div>

                {/* Direita: Formulário Workflow */}
                <div
                    id="main-form-col"
                    class:list={[
                        "lg:col-span-8 order-2",
                        !editId && "lg:col-start-3",
                    ]}
                    data-edit-id={editId}
                    data-status={editGrupo?.status}
                >
                    {/* FEEDBACKS */}
                    <div
                        id="msg-erro"
                        class="hidden mb-6 p-4 bg-red-50 text-red-800 rounded-2xl border border-red-200 font-bold text-xs"
                    >
                    </div>

                    <div
                        id="msg-sucesso"
                        class="hidden text-center py-12 bg-white rounded-[2rem] shadow-xl border border-green-200"
                    >
                        <p
                            id="success-text"
                            class="text-md font-black text-gray-900 mb-8 px-6"
                        >
                            ✅ Recebido! Em breve estará no ar.
                        </p>
                        <a
                            href="/"
                            class="inline-flex px-8 py-3 bg-[#028b3a] text-white rounded-xl font-black text-xs hover:bg-gray-950 transition-all shadow-sm uppercase tracking-widest"
                            >Explorar Grupos</a
                        >
                    </div>

                    <div
                        id="form-container"
                        class="bg-white rounded-[2.5rem] shadow-xl border border-gray-100 p-8 lg:p-12"
                    >
                        {/* STEP 1: VALIDAR LINK */}
                        <div
                            id="step-1"
                            class:list={["transition-all", editId && "hidden"]}
                        >
                            <h2
                                class="text-2xl font-black text-gray-950 mb-2 font-Inter"
                            >
                                Primeiro Passo
                            </h2>
                            <p
                                class="text-gray-500 font-medium mb-8 text-sm italic"
                            >
                                Insira o link para preenchermos os dados
                                automaticamente.
                            </p>

                            <div class="space-y-6">
                                <div>
                                    <label
                                        for="link-verify"
                                        class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-3"
                                        >Link do Grupo ou Canal</label
                                    >
                                    <input
                                        type="url"
                                        id="link-verify"
                                        placeholder="https://chat.whatsapp.com/..."
                                        class="w-full px-8 py-5 bg-gray-50 border-none rounded-2xl focus:ring-4 focus:ring-[#028b3a]/20 font-bold text-gray-800 transition-all text-lg"
                                        value={editGrupo?.link || ""}
                                    />
                                </div>

                                <button
                                    type="button"
                                    id="btn-verify"
                                    class="w-full py-5 bg-gray-950 text-white font-black text-xl rounded-3xl hover:bg-[#028b3a] transition-all active:scale-95 flex items-center justify-center gap-3"
                                >
                                    <span id="txt-verify">Validar Link</span>
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-6 w-6"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="3"
                                            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                    </svg>
                                </button>

                                <p
                                    class="text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest leading-relaxed"
                                >
                                    Segurança: Verificamos se o convite está
                                    ativo antes de continuar.
                                </p>
                            </div>
                        </div>

                        {/* STEP 2: COMPLETAR DADOS */}
                        <div
                            id="step-2"
                            class:list={[
                                "transition-all animate-in fade-in slide-in-from-right-4 duration-500",
                                !editId && "hidden",
                            ]}
                        >
                            <h2
                                class="text-2xl font-black text-gray-950 mb-6 font-Inter"
                            >
                                {
                                    editId
                                        ? "Editar Detalhes"
                                        : "Quase lá! Complete os Dados"
                                }
                            </h2>

                            {
                                !editId && (
                                    <button
                                        type="button"
                                        id="btn-back-step1"
                                        class="mb-6 text-[10px] font-black text-[#028b3a] uppercase tracking-widest hover:underline flex items-center gap-1"
                                    >
                                        ← Voltar e trocar link
                                    </button>
                                )
                            }

                            <form id="form-final" class="space-y-8">
                                <input
                                    type="hidden"
                                    id="final-foto"
                                    name="foto"
                                    value={editGrupo?.foto || ""}
                                />

                                {
                                    editId && (
                                        <div>
                                            <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">
                                                Link do Grupo
                                            </label>
                                            <input
                                                type="url"
                                                name="link"
                                                id="final-link"
                                                required
                                                class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl font-bold text-gray-800"
                                                value={editGrupo?.link || ""}
                                            />
                                        </div>
                                    )
                                }

                                {
                                    !editId && (
                                        <input
                                            type="hidden"
                                            id="final-link"
                                            name="link"
                                            value=""
                                        />
                                    )
                                }

                                <div
                                    class="grid grid-cols-1 md:grid-cols-2 gap-8"
                                >
                                    <div>
                                        <label
                                            class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2"
                                            >Tipo de Link</label
                                        >
                                        <select
                                            name="tipo"
                                            id="final-tipo"
                                            class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl font-bold text-gray-800 cursor-pointer"
                                        >
                                            <option
                                                value="grupo"
                                                selected={editGrupo?.tipo ===
                                                    "grupo"}>Grupo</option
                                            >
                                            <option
                                                value="canal"
                                                selected={editGrupo?.tipo ===
                                                    "canal"}>Canal</option
                                            >
                                        </select>
                                    </div>
                                    <div>
                                        <label
                                            class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2"
                                            >Categoria</label
                                        >
                                        <select
                                            name="categoria"
                                            required
                                            id="final-cat"
                                            class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl font-bold text-gray-800 cursor-pointer"
                                        >
                                            <option
                                                value=""
                                                disabled
                                                selected={!editGrupo}
                                                >Escolha uma categoria...</option
                                            >
                                            {
                                                todasCategorias.map((c) => (
                                                    <option
                                                        value={c.slug}
                                                        selected={
                                                            editGrupo?.categoria ===
                                                            c.slug
                                                        }
                                                    >
                                                        {c.label}
                                                    </option>
                                                ))
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div>
                                    <label
                                        class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2"
                                        >Nome Exibido</label
                                    >
                                    <input
                                        type="text"
                                        name="nome"
                                        id="final-nome"
                                        required
                                        class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl font-bold text-gray-800"
                                        value={editGrupo?.nome || ""}
                                    />
                                </div>

                                <div>
                                    <label
                                        class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2"
                                        >Descrição Curta</label
                                    >
                                    <textarea
                                        name="descricao"
                                        id="final-desc"
                                        rows="3"
                                        required
                                        placeholder="Ex: O melhor grupo para colecionadores de moedas!"
                                        class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl font-bold text-gray-800 resize-none"
                                        >{editGrupo?.descricao || ""}
                                    </textarea>
                                </div>

                                <div
                                    class="bg-gray-50/50 p-4 rounded-[1.5rem] border border-gray-100"
                                >
                                    <label
                                        class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-3 italic"
                                        >Quais são as regras? (Toque para
                                        ativar)</label
                                    >
                                    <div class="flex flex-wrap gap-1.5 mb-5">
                                        {
                                            [
                                                "Proibido Adulto",
                                                "Sem Agressividade",
                                                "Sem Palavrões",
                                                "Proibido Flood",
                                                "Só Adm Posta",
                                                "Respeite os Membros",
                                                "Sem Links Externos",
                                                "Sem Vendas",
                                                "Assunto Específico",
                                            ].map((r) => (
                                                <label class="cursor-pointer group">
                                                    <input
                                                        type="checkbox"
                                                        name="regras"
                                                        value={r}
                                                        class="hidden peer"
                                                        checked={
                                                            editGrupo
                                                                ? editGrupo.regras?.includes(
                                                                      r
                                                                  )
                                                                : [
                                                                      "Proibido Adulto",
                                                                      "Sem Agressividade",
                                                                      "Sem Palavrões",
                                                                      "Respeite os Membros",
                                                                  ].includes(r)
                                                        }
                                                    />
                                                    <span class="px-4 py-2 rounded-xl border border-gray-200 bg-white text-[10px] font-bold text-gray-500 uppercase tracking-tight transition-all peer-checked:bg-[#028b3a] peer-checked:text-white peer-checked:border-[#028b3a] group-hover:border-gray-300">
                                                        {r}
                                                    </span>
                                                </label>
                                            ))
                                        }
                                    </div>
                                    <textarea
                                        name="regras_extras"
                                        rows="2"
                                        placeholder="Outras regras (uma por linha)..."
                                        class="w-full px-4 py-3 bg-white border border-gray-100 rounded-xl text-xs font-medium text-gray-600 focus:ring-2 focus:ring-[#028b3a]/20 outline-none resize-none"
                                    ></textarea>
                                </div>

                                <div>
                                    <label
                                        class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2"
                                        >E-mail para Receber Avisos</label
                                    >
                                    <input
                                        type="email"
                                        name="email"
                                        placeholder="seu@email.com"
                                        class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl font-bold text-gray-800"
                                        value={editGrupo?.email || ""}
                                    />
                                </div>

                                <button
                                    type="submit"
                                    id="btn-enviar"
                                    class="w-full py-5 bg-[#028b3a] text-white font-black text-xl rounded-3xl shadow-xl hover:shadow-[#028b3a]/30 transition-all active:scale-95"
                                >
                                    {
                                        editId
                                            ? "Salvar Alterações"
                                            : "Publicar Agora"
                                    }
                                </button>

                                <p
                                    class="text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest leading-relaxed"
                                >
                                    Ao publicar, você concorda com nossos termos
                                    de uso e privacidade.
                                </p>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </Container>
    </Section>
</Layout>

<script>
    import { enviarGrupo, editarGrupo } from "~/lib/grupos";

    function initForm() {
        const step1 = document.getElementById("step-1");
        const step2 = document.getElementById("step-2");
        const mainFormCol = document.getElementById("main-form-col");
        if (!step1 || !step2 || !mainFormCol) return;

        const editId = mainFormCol.dataset.editId;
        const currentStatus = mainFormCol.dataset.status;

        const btnVerify = document.getElementById(
            "btn-verify"
        ) as HTMLButtonElement;
        const txtVerify = document.getElementById("txt-verify");
        const linkInput = document.getElementById(
            "link-verify"
        ) as HTMLInputElement;
        const msgErro = document.getElementById("msg-erro")!;

        // Final form elements
        const formFinal = document.getElementById(
            "form-final"
        ) as HTMLFormElement;
        const finalLink = document.getElementById(
            "final-link"
        ) as HTMLInputElement;
        const finalFoto = document.getElementById(
            "final-foto"
        ) as HTMLInputElement;
        const finalNome = document.getElementById(
            "final-nome"
        ) as HTMLInputElement;
        const finalDesc = document.getElementById(
            "final-desc"
        ) as HTMLTextAreaElement;
        const finalTipo = document.getElementById(
            "final-tipo"
        ) as HTMLSelectElement;
        const finalCat = document.getElementById(
            "final-cat"
        ) as HTMLSelectElement;

        // Preview elements
        const pNome = document.getElementById("preview-nome");
        const pDesc = document.getElementById("preview-desc");
        const pTipo = document.getElementById("preview-tipo");
        const pCat = document.getElementById("preview-cat");
        const btnBack1 = document.getElementById("btn-back-step1");

        if (linkInput && btnVerify) {
            linkInput.onkeypress = (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    btnVerify.click();
                }
            };
        }

        // Verify Link Step
        if (btnVerify) {
            btnVerify.onclick = async () => {
                const url = linkInput.value;
                if (!url) return;

                btnVerify.disabled = true;
                if (txtVerify) txtVerify.textContent = "Validando...";
                msgErro.classList.add("hidden");

                try {
                    // Adicionamos um timestamp para evitar cache do navegador
                    const res = await fetch(
                        `/api/scrape?url=${encodeURIComponent(
                            url
                        )}&t=${Date.now()}`
                    );
                    const data = await res.json();

                    if (data.status === "active") {
                        if (finalLink) finalLink.value = url;
                        if (finalFoto) finalFoto.value = data.thumb || "";
                        if (finalNome) finalNome.value = data.name || "";
                        if (finalDesc) finalDesc.value = data.description || "";

                        // Update Previews
                        if (pNome)
                            pNome.textContent = data.name || "Nome do Grupo";
                        if (pDesc)
                            pDesc.textContent =
                                data.description ||
                                "A descrição aparecerá aqui...";
                        const img = document.getElementById(
                            "preview-img"
                        ) as HTMLImageElement;
                        if (img && data.thumb) img.src = data.thumb;

                        step1.classList.add("hidden");
                        step2.classList.remove("hidden");
                        document
                            .getElementById("preview-container")
                            ?.classList.remove("hidden");
                        mainFormCol.classList.remove("lg:col-start-3");
                    } else {
                        msgErro.textContent =
                            data.error ||
                            "Link inválido. Verifique se o convite não expirou.";
                        msgErro.classList.remove("hidden");
                    }
                } catch (err) {
                    msgErro.textContent =
                        "Ops! Tivemos um problema técnico. Tente novamente.";
                    msgErro.classList.remove("hidden");
                } finally {
                    btnVerify.disabled = false;
                    if (txtVerify) txtVerify.textContent = "Validar Link";
                }
            };
        }

        if (btnBack1) {
            btnBack1.onclick = () => {
                step2.classList.add("hidden");
                step1.classList.remove("hidden");
                document
                    .getElementById("preview-container")
                    ?.classList.add("hidden");
                mainFormCol.classList.add("lg:col-start-3");
            };
        }

        // Real-time Preview logic
        [finalNome, finalDesc, finalTipo, finalCat].forEach((el) => {
            el?.addEventListener("input", () => {
                if (pNome)
                    pNome.textContent = finalNome.value || "Nome do Grupo";
                const desc = finalDesc.value || "A descrição aparecerá aqui...";
                if (pDesc) pDesc.textContent = desc;
                if (pTipo)
                    pTipo.textContent = (finalTipo.value || "").toUpperCase();
                if (pCat)
                    pCat.textContent =
                        finalCat.options[
                            finalCat.selectedIndex
                        ]?.text.toUpperCase() || "CATEGORIA";
            });
        });

        // Final Form Submission
        if (formFinal) {
            formFinal.onsubmit = async (e) => {
                e.preventDefault();
                const btn = document.getElementById(
                    "btn-enviar"
                ) as HTMLButtonElement;
                btn.disabled = true;
                btn.textContent = editId
                    ? "Salvando Alterações..."
                    : "Publicando...";

                const formData = new FormData(formFinal);
                const regrasMarcadas = formData.getAll("regras") as string[];
                const regrasExtrasRaw = formData.get("regras_extras") as string;
                const regrasExtras = regrasExtrasRaw
                    ? (regrasExtrasRaw as string)
                          .split("\n")
                          .map((r) => r.trim())
                          .filter((r) => r.length > 0)
                    : [];
                const regras = [...regrasMarcadas, ...regrasExtras];

                const link = formData.get("link") as string;
                const valLink = link.toLowerCase();
                const isWhatsapp =
                    valLink.includes("chat.whatsapp.com") ||
                    valLink.includes("whatsapp.com/channel");

                if (!isWhatsapp) {
                    msgErro.textContent =
                        "Insira um link válido do WhatsApp (Grupo ou Canal).";
                    msgErro.classList.remove("hidden");
                    btn.disabled = false;
                    btn.textContent = editId
                        ? "Salvar Alterações"
                        : "Publicar Agora";
                    window.scrollTo({ top: 0, behavior: "smooth" });
                    return;
                }

                const dados = {
                    nome: formData.get("nome") as string,
                    descricao: formData.get("descricao") as string,
                    categoria: formData.get("categoria") as string,
                    tipo: formData.get("tipo") as "grupo" | "canal",
                    link: link,
                    foto: formData.get("foto") as string,
                    email: (formData.get("email") as string) || undefined,
                    regras: regras,
                };

                try {
                    if (editId) {
                        await editarGrupo(editId, dados, currentStatus);
                    } else {
                        const id = await enviarGrupo(dados);

                        // Notifica sobre o recebimento se o e-mail foi fornecido
                        if (dados.email) {
                            try {
                                fetch("/api/notificar-recebimento.json", {
                                    method: "POST",
                                    headers: {
                                        "Content-Type": "application/json",
                                    },
                                    body: JSON.stringify({
                                        email: dados.email,
                                        nome: dados.nome,
                                    }),
                                }).catch((err) =>
                                    console.error(
                                        "Erro ao notificar backend sobre recebimento:",
                                        err
                                    )
                                );
                            } catch (e) {
                                /* ignore */
                            }
                        }

                        // Salvar no localStorage para o usuário gerenciar
                        const meusGrupos = JSON.parse(
                            localStorage.getItem("meus_grupos") || "[]"
                        );
                        if (!meusGrupos.includes(id)) {
                            meusGrupos.push(id);
                            localStorage.setItem(
                                "meus_grupos",
                                JSON.stringify(meusGrupos)
                            );
                        }
                    }

                    const previewCont =
                        document.getElementById("preview-container");
                    const fCol = document.getElementById("main-form-col")!;
                    previewCont?.classList.add("hidden");
                    fCol.classList.add("lg:col-start-3");

                    document
                        .getElementById("form-container")!
                        .classList.add("hidden");
                    const msgSucesso = document.getElementById("msg-sucesso")!;
                    const successText =
                        document.getElementById("success-text")!;
                    if (editId) {
                        successText.textContent =
                            currentStatus === "aprovado"
                                ? "✅ Suas alterações foram atualizadas."
                                : "✅ Recebido! Em breve será revisado.";
                    }
                    msgSucesso.classList.remove("hidden");
                    window.scrollTo({ top: 0, behavior: "smooth" });
                } catch (err) {
                    console.error(err);
                    msgErro.textContent =
                        "Erro ao salvar seu grupo. Tente novamente.";
                    msgErro.classList.remove("hidden");
                    btn.disabled = false;
                    btn.textContent = editId
                        ? "Tentar Novamente"
                        : "Finalizar Cadastro";
                }
            };
        }
    }

    // Inicializa o formulário para a primeira carga e navegações subsequentes (View Transitions)
    document.addEventListener("astro:page-load", initForm);
</script>
