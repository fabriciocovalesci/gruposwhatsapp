---
import Layout from '~/layouts/Layout.astro';
import { categoriasPorGrupo, todasCategorias } from '~/lib/categorias';

const title = 'Grupos WhatsApp';
const description = 'Encontre grupos e canais do WhatsApp por categoria. Tecnologia, finanças, educação, entretenimento e muito mais.';
---

<Layout pageTitle={`${title} | WhatsDir`} title={title} description={description}>

  <!-- Hero -->
  <section class="bg-yellow-200">
    <div class="container py-10 lg:py-16">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <div>
          <p class="text-base font-semibold text-gray-500 mb-2">WhatsDir</p>
          <h1 class="h2">{title}</h1>
          <p class="text-lg text-gray-700 mt-2 max-w-xl">{description}</p>
        </div>
        <a href="/grupos/enviar" class="button button-black shrink-0">
          + Enviar grupo
        </a>
      </div>
    </div>
  </section>

  <!-- Corpo: sidebar + lista -->
  <section class="bg-white">
    <div class="container py-8 lg:py-12">
      <div class="lg:flex gap-x-8 items-start">

        <!-- Sidebar de categorias (desktop fixo, mobile drawer) -->
        <aside
          id="sidebar-grupos"
          class="fixed lg:relative max-lg:overflow-y-auto shrink-0 inset-y-0 left-0 z-50
                 w-72 bg-white lg:flex lg:flex-col
                 max-lg:opacity-0 max-lg:pointer-events-none transition duration-300"
        >
          <div class="flex lg:sticky lg:top-8 flex-col gap-y-1 bg-white lg:shadow-md px-4 py-4">
            <!-- Fechar (mobile) -->
            <div class="flex justify-between items-center mb-2 lg:hidden">
              <span class="font-bold text-lg">Categorias</span>
              <button id="btn-fechar-sidebar" class="size-8 flex items-center justify-center bg-gray-800 rounded-full text-white" aria-label="Fechar">
                <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>

            <!-- Todas -->
            <button
              class="cat-btn text-left w-full px-3 py-2 text-base font-semibold transition hover:bg-yellow-100 rounded active-cat"
              data-cat=""
            >
              Todos
            </button>

            <!-- Grupos tematicos -->
            {categoriasPorGrupo.map(grupo => (
              <details class="group" open>
                <summary class="cursor-pointer px-3 py-2 text-sm font-semibold text-gray-500 uppercase tracking-wide list-none flex items-center justify-between hover:text-gray-800 select-none">
                  {grupo.grupo}
                  <svg class="size-4 transition group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
                  </svg>
                </summary>
                <div class="pl-2 flex flex-col gap-0.5 mt-0.5">
                  {grupo.items.map(cat => (
                    <button
                      class="cat-btn text-left w-full px-3 py-1.5 text-base transition hover:bg-yellow-100 rounded"
                      data-cat={cat.slug}
                    >
                      {cat.label}
                    </button>
                  ))}
                </div>
              </details>
            ))}
          </div>
        </aside>

        <!-- Overlay mobile -->
        <div id="overlay-sidebar" class="fixed inset-0 z-40 bg-black/30 opacity-0 pointer-events-none transition lg:hidden"></div>

        <!-- Conteudo principal -->
        <div class="flex-1 min-w-0">

          <!-- Barra: busca + filtro tipo + btn mobile -->
          <div class="flex flex-wrap gap-3 items-center mb-6">
            <!-- Botao abrir sidebar (mobile) -->
            <button id="btn-abrir-sidebar" class="button button-yellow lg:hidden">
              <svg class="size-5 mr-2 inline-block" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M2.628 1.601C5.028 1.206 7.49 1 10 1s4.973.206 7.372.601a.75.75 0 01.628.74v2.288a2.25 2.25 0 01-.659 1.59l-4.682 4.683a2.25 2.25 0 00-.659 1.59v3.037c0 .684-.31 1.33-.844 1.757l-1.937 1.55A.75.75 0 018 18.25v-5.757a2.25 2.25 0 00-.659-1.591L2.659 6.22A2.25 2.25 0 012 4.629V2.34a.75.75 0 01.628-.74z" clip-rule="evenodd"/>
              </svg>
              Categorias
            </button>

            <!-- Busca -->
            <div class="flex-1 min-w-48">
              <input
                id="input-busca"
                type="search"
                placeholder="Buscar grupos..."
                class="mt-0!"
              />
            </div>

            <!-- Filtro tipo -->
            <select id="select-tipo" class="mt-0! w-auto">
              <option value="">Todos os tipos</option>
              <option value="grupo">Grupos</option>
              <option value="canal">Canais</option>
            </select>
          </div>

          <!-- Categoria ativa (label) -->
          <div id="label-categoria" class="hidden mb-4 flex items-center gap-2">
            <span class="font-semibold text-base" id="text-categoria"></span>
            <button id="btn-limpar-cat" class="text-sm text-gray-400 hover:text-gray-800 underline">Limpar filtro</button>
          </div>

          <!-- Loading -->
          <div id="loading" class="flex items-center gap-3 py-16 text-gray-400">
            <svg class="animate-spin size-5" viewBox="0 0 24 24" fill="none">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
            </svg>
            Carregando grupos...
          </div>

          <!-- Vazio -->
          <div id="lista-vazia" class="hidden text-center py-16 text-gray-400">
            <p class="text-5xl mb-4"></p>
            <p class="text-lg font-semibold">Nenhum grupo encontrado</p>
            <p class="text-base mt-1">Tente outro filtro ou <a href="/grupos/enviar" class="underline hover:text-gray-800">envie o seu grupo</a>.</p>
          </div>

          <!-- Grid de grupos (renderizado via JS) -->
          <ul id="lista-grupos" class="hidden grid grid-cols-1 gap-4"></ul>

          <!-- Contador -->
          <p id="contador" class="hidden text-base text-gray-400 mt-4"></p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<!-- Template do card -->
<template id="tpl-card">
  <li class="card-grupo bg-white shadow overflow-hidden transition border-transparent border-l-4 hover:border-yellow-300">
    <div class="flex items-start gap-4 p-4 xxl:p-6">
      <img class="c-foto size-12 shrink-0 rounded-full object-cover border border-gray-100" src="" alt="" width="48" height="48" />
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center gap-2 mb-1">
          <h3 class="c-nome h6 truncate"></h3>
          <span class="c-tipo text-sm font-semibold px-2 py-0.5 rounded"></span>
          <span class="c-destaque hidden bg-yellow-200 text-gray-800 text-sm font-semibold px-2 py-0.5 rounded">Destaque</span>
        </div>
        <p class="c-membros text-base text-gray-400 mb-1 hidden"></p>
        <p class="c-desc text-base line-clamp-2 text-gray-600"></p>
      </div>
    </div>
    <div class="flex items-center justify-between px-4 xxl:px-6 pb-4 gap-4">
      <a class="c-cat text-base text-gray-400 hover:text-gray-800 hover:underline transition truncate" href="#"></a>
      <a class="c-link button button-black shrink-0" href="#" target="_blank" rel="noopener noreferrer">
        Entrar
        <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 size-4 inline-block" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </a>
    </div>
  </li>
</template>

<script>
  // Elementos
  const listaEl      = document.getElementById('lista-grupos')!;
  const loadingEl    = document.getElementById('loading')!;
  const vazioEl      = document.getElementById('lista-vazia')!;
  const contadorEl   = document.getElementById('contador')!;
  const buscaEl      = document.getElementById('input-busca') as HTMLInputElement;
  const tipoEl       = document.getElementById('select-tipo') as HTMLSelectElement;
  const labelCatEl   = document.getElementById('label-categoria')!;
  const textCatEl    = document.getElementById('text-categoria')!;
  const btnLimpar    = document.getElementById('btn-limpar-cat')!;
  const catBtns      = document.querySelectorAll<HTMLElement>('.cat-btn');
  const tpl          = document.getElementById('tpl-card') as HTMLTemplateElement;
  const btnAbrir     = document.getElementById('btn-abrir-sidebar')!;
  const btnFechar    = document.getElementById('btn-fechar-sidebar')!;
  const sidebar      = document.getElementById('sidebar-grupos')!;
  const overlay      = document.getElementById('overlay-sidebar')!;

  interface GrupoData {
    nome: string; descricao: string; categoria: string; tipo: string;
    link: string; membros?: number; destaque?: boolean; foto?: string;
  }

  let todosGrupos: GrupoData[] = [];
  let catAtiva = '';

  // Sidebar mobile
  function abrirSidebar() {
    sidebar.classList.remove('max-lg:opacity-0', 'max-lg:pointer-events-none');
    sidebar.classList.add('max-lg:opacity-100');
    overlay.classList.remove('opacity-0', 'pointer-events-none');
    overlay.classList.add('opacity-100');
  }
  function fecharSidebar() {
    sidebar.classList.add('max-lg:opacity-0', 'max-lg:pointer-events-none');
    sidebar.classList.remove('max-lg:opacity-100');
    overlay.classList.add('opacity-0', 'pointer-events-none');
    overlay.classList.remove('opacity-100');
  }
  btnAbrir.addEventListener('click', abrirSidebar);
  btnFechar.addEventListener('click', fecharSidebar);
  overlay.addEventListener('click', fecharSidebar);

  // Categorias
  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      catAtiva = btn.dataset.cat ?? '';
      catBtns.forEach(b => b.classList.remove('active-cat', 'bg-yellow-200'));
      btn.classList.add('active-cat', 'bg-yellow-200');
      if (catAtiva) {
        labelCatEl.classList.remove('hidden');
        textCatEl.textContent = btn.textContent?.trim() ?? catAtiva;
      } else {
        labelCatEl.classList.add('hidden');
      }
      fecharSidebar();
      filtrarERenderizar();
    });
  });

  btnLimpar.addEventListener('click', () => {
    catAtiva = '';
    catBtns.forEach(b => b.classList.remove('active-cat', 'bg-yellow-200'));
    document.querySelector<HTMLElement>('.cat-btn[data-cat=""]')?.classList.add('active-cat', 'bg-yellow-200');
    labelCatEl.classList.add('hidden');
    filtrarERenderizar();
  });

  buscaEl.addEventListener('input', filtrarERenderizar);
  tipoEl.addEventListener('change', filtrarERenderizar);

  async function carregar() {
    try {
      const res = await fetch('/api/getGrupos.json?status=aprovado');
      if (!res.ok) throw new Error('Erro na API');
      todosGrupos = await res.json();
      filtrarERenderizar();
    } catch (e) {
      console.error(e);
      loadingEl.textContent = 'Erro ao carregar grupos. Tente novamente.';
    }
  }

  function filtrarERenderizar() {
    const busca = buscaEl.value.toLowerCase().trim();
    const tipo  = tipoEl.value;

    const filtrados = todosGrupos.filter(g => {
      if (catAtiva && g.categoria !== catAtiva) return false;
      if (tipo && g.tipo !== tipo) return false;
      if (busca && !g.nome.toLowerCase().includes(busca) && !g.descricao.toLowerCase().includes(busca)) return false;
      return true;
    });

    renderizar(filtrados);
  }

  function renderizar(grupos: GrupoData[]) {
    loadingEl.classList.add('hidden');
    listaEl.innerHTML = '';

    if (grupos.length === 0) {
      vazioEl.classList.remove('hidden');
      listaEl.classList.add('hidden');
      contadorEl.classList.add('hidden');
      return;
    }

    vazioEl.classList.add('hidden');
    listaEl.classList.remove('hidden');
    contadorEl.classList.remove('hidden');
    contadorEl.textContent = `${grupos.length} grupo${grupos.length !== 1 ? 's' : ''} encontrado${grupos.length !== 1 ? 's' : ''}`;

    grupos.forEach(g => {
      const clone = tpl.content.cloneNode(true) as DocumentFragment;
      const avatarUrl = g.foto
        ?? `https://ui-avatars.com/api/?name=${encodeURIComponent(g.nome.slice(0,2))}&background=${g.tipo==='canal'?'25D366':'128C7E'}&color=fff&size=128&bold=true&rounded=true`;

      (clone.querySelector('.c-foto') as HTMLImageElement).src = avatarUrl;
      (clone.querySelector('.c-foto') as HTMLImageElement).alt = g.nome;
      clone.querySelector('.c-nome')!.textContent = g.nome;
      clone.querySelector('.c-desc')!.textContent = g.descricao;
      (clone.querySelector('.c-cat') as HTMLAnchorElement).textContent = g.categoria;
      (clone.querySelector('.c-cat') as HTMLAnchorElement).href = `/grupos/categoria/${g.categoria}`;
      (clone.querySelector('.c-link') as HTMLAnchorElement).href = g.link;

      const tipoBadge = clone.querySelector('.c-tipo')!;
      if (g.tipo === 'canal') {
        tipoBadge.textContent = 'Canal';
        tipoBadge.classList.add('bg-green-100', 'text-green-700');
      } else {
        tipoBadge.textContent = 'Grupo';
        tipoBadge.classList.add('bg-teal-100', 'text-teal-700');
      }

      if (g.destaque) clone.querySelector('.c-destaque')!.classList.remove('hidden');

      if (g.membros != null) {
        const membrosEl = clone.querySelector('.c-membros')!;
        membrosEl.textContent = `${g.membros.toLocaleString('pt-BR')} membros`;
        membrosEl.classList.remove('hidden');
      }

      listaEl.appendChild(clone);
    });
  }

  carregar();
</script>

<style>
  .active-cat { background-color: #fef08a; font-weight: 700; }
  details > summary::-webkit-details-marker { display: none; }
</style>
