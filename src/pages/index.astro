---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import { siteName, siteDomain } from "~/data/config";
import {
	getGruposPaginados,
	getGruposDestaque,
	todasCategorias,
} from "~/lib/grupos";
import GroupCard from "~/components/GroupCard.astro";

const faqItems = [
	{
		question: `O que é o ${siteName}?`,
		answer: `Nós somos a maior plataforma brasileira de links de grupos de WhatsApp. No ${siteDomain} você descobre comunidades reais para participar e também pode divulgar o seu próprio grupo gratuitamente. Nossa missão é conectar pessoas com interesses em comum de forma rápida, segura e sem limites de participação.`,
	},
	{
		question: "Como encontrar um grupo de WhatsApp?",
		answer: `Para encontrar grupos de whatsapp, navegue pelas categorias no topo do site ou use a busca. Temos mais de 40 temas como amizade, figurinhas, namoro e negócios. Acesse ${siteDomain} e explore as milhares de opções atualizadas diariamente.`,
	},
	{
		question: "Como entrar em um grupo através do site?",
		answer:
			"Escolha o grupo desejado, clique no card e aperte o botão 'Participar do Grupo'. O seu WhatsApp abrirá automaticamente na tela de convite oficial. É o jeito mais fácil de entrar em grupos de whatsapp online.",
	},
	{
		question: "Como criar o seu próprio grupo de WhatsApp?",
		answer:
			"No WhatsApp, clique em 'Novo grupo', selecione os contatos, escolha um nome legal e adicione uma foto. Para crescer rápido, pegue o link de convite e cadastre aqui no nosso portal para conseguir novos membros todo dia!",
	},
	{
		question: "Como excluir um grupo definitivamente?",
		answer:
			"Como administrador, remova todos os membros. Depois, clique em 'Sair do grupo' e 'Excluir grupo'. Isso garante que o grupo não continue ativo com outra pessoa.",
	},
	{
		question: "Como sair de um grupo que não quero mais?",
		answer:
			"Abra o grupo > clique no nome no topo > role até o final > 'Sair do grupo'. Simples assim para deixar de receber mensagens de qualquer comunidade.",
	},
	{
		question: "Como adicionar pessoas ao meu grupo?",
		answer: `Sendo administrador, use 'Adicionar participantes' ou gere um 'Link de convite' nas configurações do grupo. Divulgar esse link no ${siteName} é a melhor forma de atrair novas pessoas interessantes.`,
	},
	{
		question: "Como fazer chamadas em grupo?",
		answer:
			"O WhatsApp permite ligar para até 32 pessoas de uma vez! No grupo, use o ícone de telefone com o sinal '+', selecione quem deseja e escolha entre áudio ou vídeo.",
	},
	{
		question: "Quantas pessoas cabem em um grupo hoje?",
		answer:
			"Atualmente, o limite é de 1.024 pessoas por grupo. O WhatsApp expandiu esse limite para permitir comunidades maiores e mais organizadas.",
	},
];

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: faqItems.map(({ question, answer }) => ({
		"@type": "Question",
		name: question,
		acceptedAnswer: {
			"@type": "Answer",
			text: answer,
		},
	})),
};

// 1. Busca os fixados (destaque)
const fixados = await getGruposDestaque(10);
const idsFixados = new Set(fixados.map((g) => g.id));

// 2. Busca o primeiro lote normal (10)
const { grupos: normalBatch, lastId: initialLastId } = await getGruposPaginados(
	10
);

// 3. Combina: Fixados no topo + Lote normal (filtrando quem ja eh fixado)
const grupos = [
	...fixados,
	...normalBatch.filter((g) => !idsFixados.has(g.id)),
];
const hasMore = normalBatch.length === 10;
---

<Layout
	pageTitle="gruposwhatsapp.online - Links de Grupos de WhatsApp"
	description="Encontre os melhores links de grupos de WhatsApp, canais, namoro, amizade e muito mais. Mande seu grupo e consiga mais membros gratis!"
>
	<script
		type="application/ld+json"
		set:html={JSON.stringify(faqSchema)}
	/>
	{/* Hero Section - Matching Hyperdrive Soul */}
	<Section
		class:list={"bg-[#028b3a] pt-16 pb-28 lg:pt-24 lg:pb-40 relative overflow-hidden text-white"}
	>
		{/* Subtle overlays for dept (similar to original) */}
		<div class="absolute inset-0 bg-black/10 mix-blend-overlay"></div>

		<Container class="relative z-10">
			<div class="max-w-4xl mx-auto text-center">
				<h1
					class="text-4xl lg:text-7xl font-black text-white tracking-tight mb-8 leading-[1.1]"
				>
					Encontre agora os melhores <br class="hidden lg:block" />
					<span class="text-black/50">Grupos de WhatsApp</span>
				</h1>
				<p
					class="text-lg lg:text-2xl text-white mb-14 max-w-2xl mx-auto font-medium leading-relaxed"
				>
					Milhares de links ativos verificados para você entrar e
					conversar. Navegue pelas categorias e ache sua nova
					comunidade.
				</p>

				{/* Search Bar - Replicating Original Search Proportions */}
				<div class="max-w-3xl mx-auto">
					<form
						action="/categorias"
						method="get"
						class="relative group"
					>
						<div
							class="flex flex-col md:flex-row gap-3 p-3 bg-white/10 backdrop-blur-md rounded-3xl lg:rounded-[2.5rem] border border-white/20 shadow-2xl"
						>
							<input
								type="text"
								name="search"
								placeholder="Pesquise por nome, assunto ou categoria..."
								class="flex-1 px-8 py-5 bg-white rounded-2xl lg:rounded-[2rem] text-lg shadow-sm border-none text-gray-800 font-semibold focus:ring-0"
							/>
							<button
								type="submit"
								class="bg-[#075E54] text-white px-10 py-5 rounded-2xl lg:rounded-[2rem] font-bold text-lg hover:bg-gray-900 transition-all flex items-center justify-center gap-2 shadow-lg active:scale-95"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									class="h-6 w-6"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="3"
										d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
									></path>
								</svg>
								<span>Buscar Grupos</span>
							</button>
						</div>
					</form>
				</div>
			</div>
		</Container>
	</Section>

	{/* Quick Categories Slider */}
	<div class="-mt-10 lg:-mt-12 relative z-20">
		<Container>
			<div
				class="bg-white rounded-3xl shadow-xl border border-gray-100 p-3 lg:p-5 overflow-x-auto no-scrollbar"
			>
				<div class="flex items-center gap-3">
					<div
						class="hidden lg:flex items-center gap-2 px-4 border-r border-gray-100 flex-shrink-0"
					>
						<span
							class="text-red-500 font-black text-lg animate-pulse"
							>🔥</span
						>
						<span
							class="text-xs font-bold text-gray-500 uppercase tracking-widest"
							>Bombando:</span
						>
					</div>
					{
						todasCategorias.slice(0, 15).map((cat) => (
							<a
								href={`/categorias/${cat.slug}`}
								class="px-6 py-3 bg-gray-50 hover:bg-[#E8F8F5] text-gray-700 hover:text-[#25D366] rounded-2xl text-sm font-bold border border-transparent transition-all flex-shrink-0"
							>
								{cat.label}
							</a>
						))
					}
					<a
						href="/categorias"
						class="px-6 py-3 text-[#028b3a] font-bold text-sm whitespace-nowrap hover:underline"
						>Ver todas as {todasCategorias.length} →</a
					>
				</div>
			</div>
		</Container>
	</div>

	{/* Últimos Grupos - Infinite Scroll */}
	<Section class:list={"pt-4 pb-12 lg:pt-6 lg:pb-20 bg-gray-50"}>
		<Container>
			<div
				class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16"
			>
				<div class="max-w-2xl">
					<span
						class="text-[#028B3A] font-black uppercase tracking-[0.2em] text-sm mb-4 block"
						>Em Destaque</span
					>
					<h2
						class="text-3xl lg:text-5xl font-black text-gray-950 tracking-tighter leading-tight"
					>
						Explore os últimos <span class="text-[#028B3A]"
							>Grupos</span
						> do nosso diretório
					</h2>
				</div>
				<a
					href="/categorias"
					class="inline-flex items-center gap-2 text-lg font-black text-gray-950 hover:text-[#028B3A] transition-colors group"
				>
					Veja Todas Categorias
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-6 w-6 group-hover:translate-x-1 transition-transform"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="3"
							d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
					</svg>
				</a>
			</div>

			<div
				id="grupos-grid"
				class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
				data-last-id={initialLastId}
				data-has-more={hasMore ? "true" : "false"}
			>
				{grupos.map((grupo) => <GroupCard grupo={grupo} />)}
			</div>

			<div
				id="loading-trigger"
				class:list={[
					"w-full flex justify-center py-20",
					!hasMore && "hidden",
				]}
			>
				<div class="flex flex-col items-center gap-4">
					<div
						class="size-10 border-4 border-[#028B3A]/20 border-t-[#028B3A] rounded-full animate-spin"
					>
					</div>
					<p
						class="text-[10px] font-black uppercase tracking-widest text-[#028B3A]"
					>
						Carregando mais links...
					</p>
				</div>
			</div>
		</Container>
	</Section>

	{/* Call to Action - Clean & Premium */}
	<Section class:list={"bg-gray-900 py-24 lg:py-48 relative overflow-hidden"}>
		<div
			class="absolute inset-0 bg-[#028b3a] opacity-5 pointer-events-none"
		>
		</div>
		<Container class="relative z-10">
			<div class="text-center max-w-4xl mx-auto">
				<span
					class="inline-flex items-center px-4 py-1.5 rounded-full bg-[#028b3a] text-white text-[10px] font-black uppercase tracking-widest mb-10 shadow-lg"
					>Ganhe novos membros hoje</span
				>
				<h2
					class="text-5xl lg:text-8xl font-bold text-white leading-[1.05] mb-10 tracking-tighter"
				>
					Turbine o seu <span class="text-[#028b3a]">Link</span> Gratuitamente.
				</h2>
				<p
					class="text-gray-400 text-xl lg:text-2xl mb-16 font-medium leading-relaxed max-w-2xl mx-auto"
				>
					Divulgue para milhares de pessoas que buscam novos grupos
					diariamente. É 100% grátis e seguro.
				</p>
				<a
					href="/enviar-grupo"
					class="inline-flex items-center justify-center px-12 py-6 text-xl lg:text-2xl font-bold text-gray-900 bg-[#25D366] rounded-3xl hover:bg-white transition-all shadow-2xl shadow-[#25D366]/20 active:scale-95"
				>
					Quero Cadastrar Meu Grupo
				</a>
			</div>
		</Container>
	</Section>

	{/* Guias e FAQ - Comprehensive Section */}
	<Section class:list={"py-24 lg:py-40 bg-white"}>
		<Container>
			<div
				class="max-w-3xl prose mb-16 text-center mx-auto transition-all"
			>
				<h2 class="text-balance">Tudo sobre o WhatsApp</h2>
				<p>
					Preparamos esse guia completo para você tirar todas as suas
					dúvidas sobre o aplicativo, gerenciar seus grupos e
					aproveitar ao máximo o nosso diretório.
				</p>
			</div>

			<div class="max-w-4xl mx-auto">
				<div class="grid gap-6">
					{
						faqItems.map((item) => (
							<details class="group bg-gray-50 rounded-3xl p-8 cursor-pointer border border-transparent hover:border-gray-200 transition-all">
								<summary class="flex justify-between items-center list-none">
									<h3 class="text-xl lg:text-2xl font-bold text-gray-900 group-open:text-[#25D366] transition-colors">
										{item.question}
									</h3>
									<div class="bg-white rounded-full p-2 shadow-sm group-open:rotate-180 transition-transform">
										<svg
											xmlns="http://www.w3.org/2000/svg"
											class="h-6 w-6 text-gray-400"
											fill="none"
											viewBox="0 0 24 24"
											stroke="currentColor"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M19 9l-7 7-7-7"
											/>
										</svg>
									</div>
								</summary>
								<div class="mt-8 text-gray-500 text-lg leading-relaxed font-medium">
									{item.answer}
								</div>
							</details>
						))
					}
				</div>
			</div>
		</Container>
	</Section>
</Layout>

<script>
	import { getLabelCategoria } from "~/lib/categorias";

	function initInfiniteScroll() {
		const grid = document.getElementById("grupos-grid");
		const trigger = document.getElementById("loading-trigger");
		if (!grid || !trigger) return;

		let lastId = grid.dataset.lastId;
		let hasMore = grid.dataset.hasMore === "true";
		let isLoading = false;

		const observer = new IntersectionObserver(
			async (entries) => {
				if (entries[0].isIntersecting && hasMore && !isLoading) {
					isLoading = true;
					try {
						const res = await fetch(
							`/api/grupos-paginados.json?limit=10&lastId=${lastId}`
						);
						const data = await res.json();

						if (data.grupos && data.grupos.length > 0) {
							data.grupos.forEach((grupo: any) => {
								const card = createCard(grupo);
								grid.appendChild(card);
							});
							lastId = data.lastId;
							hasMore = data.grupos.length === 10;
							if (!hasMore) trigger.classList.add("hidden");
						} else {
							hasMore = false;
							trigger.classList.add("hidden");
						}
					} catch (err) {
						console.error(err);
					} finally {
						isLoading = false;
					}
				}
			},
			{ rootMargin: "200px" }
		);

		observer.observe(trigger);

		function createCard(grupo: any) {
			const div = document.createElement("div");
			const labelCat =
				getLabelCategoria(grupo.categoria) || grupo.categoria;
			const avatarUrl =
				grupo.foto ||
				`https://ui-avatars.com/api/?name=${encodeURIComponent(
					grupo.nome.slice(0, 2)
				)}&background=${
					grupo.tipo === "canal" ? "25D366" : "128C7E"
				}&color=fff&size=128&bold=true&rounded=true`;

			div.className = `bg-white rounded-[2rem] shadow-sm border border-gray-200 overflow-hidden hover:shadow-2xl hover:-translate-y-1 hover:border-[#25D366]/40 transition-all group flex flex-col h-full relative ${
				grupo.destaque
					? "border-[#FFD700] shadow-xl shadow-[#FFD700]/5"
					: ""
			}`;

			div.innerHTML = `
				${
					grupo.destaque
						? `
				<div class="absolute top-6 right-6 z-10 bg-white size-8 rounded-full shadow-lg border border-[#FFD700]/20 flex items-center justify-center animate-pulse">
					<svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-[#FFD700]" viewBox="0 0 20 20" fill="currentColor">
						<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
					</svg>
				</div>
				`
						: ""
				}

				<div class="p-6 flex-1">
					<div class="flex items-center gap-4 mb-5">
						<div class="relative">
							<img src="${avatarUrl}" alt="${
				grupo.nome
			}" class="w-16 h-16 rounded-3xl object-cover border-2 border-gray-50 flex-shrink-0 group-hover:scale-110 transition-transform duration-500 shadow-sm" />
							<div class="absolute -bottom-1 -right-1 size-5 rounded-full border-2 border-white ${
								grupo.tipo === "canal"
									? "bg-[#25D366]"
									: "bg-teal-500"
							} shadow-sm"></div>
						</div>
						<div class="flex-1 min-w-0">
							<div class="flex items-center gap-2 mb-1">
								<span class="text-[10px] font-black uppercase tracking-widest px-2 py-0.5 rounded-lg ${
									grupo.tipo === "canal"
										? "bg-green-100 text-[#075E54]"
										: "bg-teal-100 text-teal-900"
								}">${grupo.tipo}</span>
								<span class="text-[10px] font-black uppercase tracking-widest px-2 py-0.5 rounded-lg bg-gray-100 text-gray-700">${labelCat.toUpperCase()}</span>
							</div>
							<h5 class="font-black text-gray-950 text-lg truncate group-hover:text-[#028b3a] transition-colors leading-tight">${
								grupo.nome
							}</h5>
						</div>
					</div>
					<p class="text-gray-600 font-medium line-clamp-3 text-sm leading-relaxed mb-2">${
						grupo.descricao
					}</p>
				</div>

				<div class="px-6 pb-6 mt-auto">
					<a href="/grupo/${
						grupo.id
					}" aria-label="Participar" class="w-full inline-flex items-center justify-center gap-2 px-6 py-4 text-base font-black text-white bg-[#028b3a] rounded-2xl hover:bg-[#075E54] transition-all shadow-lg hover:shadow-[#028b3a]/30 active:scale-95 group-hover:bg-[#075E54]">
						<span>Participar</span>
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
						</svg>
					</a>
					<div class="mt-4 flex justify-center">
						<a href="/categorias/${
							grupo.categoria
						}" class="text-[11px] font-black text-gray-600 uppercase tracking-widest hover:text-[#028b3a] transition-colors">Ver mais ${labelCat}</a>
					</div>
				</div>
			`;
			return div;
		}
	}

	initInfiniteScroll();
	document.addEventListener("astro:after-swap", initInfiniteScroll);
	document.addEventListener("astro:page-load", initInfiniteScroll);
</script>

<style>
	.no-scrollbar::-webkit-scrollbar {
		display: none;
	}
	.no-scrollbar {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
