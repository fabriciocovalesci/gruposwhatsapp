---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import {
    getGruposAprovados,
    todasCategorias,
    getLabelCategoria,
} from "~/lib/grupos";
import ShowGroups from "~/components/ShowGroups.astro";

// Gerar as páginas estáticas para cada categoria
export function getStaticPaths() {
    return todasCategorias.map((cat) => {
        return {
            params: { categoria: cat.slug },
        };
    });
}

const { categoria } = Astro.params;
if (!categoria) throw new Error("Categoria não encontrada");
const label = getLabelCategoria(categoria) || categoria;

// Obter grupos
// Em um app real enorme, filtraríamos no backend. Aqui para SSG podemos filtrar no build
const todosGrupos = await getGruposAprovados();
const gruposDaCategoria = todosGrupos.filter((g) => g.categoria === categoria);
---

<Layout
    pageTitle={`Grupos de ${label} no WhatsApp - gruposwhatsapp.online`}
    description={`Os melhores links de grupos e canais de WhatsApp de ${label}. Atualizado diariamente.`}
>
    <Section class:list={"pt-6 pb-20 bg-white min-h-[70vh]"}>
        <Container>
            <div class="mb-10 text-center lg:text-left">
                <h1
                    class="text-2xl lg:text-4xl font-bold text-gray-950 tracking-tight"
                >
                    Grupos de <span class="text-[#25D366]">{label}</span>
                </h1>
                <p class="text-sm text-gray-500 font-medium lg:max-w-xl">
                    Participar de comunidades reais de {label} no WhatsApp. Atualizado
                    diariamente.
                </p>
            </div>

            <div
                class="flex flex-col md:flex-row md:items-end justify-between mb-8 border-b border-gray-100 pb-6 gap-6"
            >
                <div>
                    <span
                        class="text-[#25D366] font-bold uppercase tracking-[0.2em] text-[10px] mb-2 block"
                        >Listagem de Grupos</span
                    >
                    <h2
                        class="text-2xl lg:text-3xl font-bold text-gray-950 tracking-tight"
                    >
                        {gruposDaCategoria.length} Disponíveis
                    </h2>
                </div>
                <a
                    href="/enviar-grupo"
                    class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-gray-900 text-white rounded-2xl font-bold hover:bg-[#25D366] transition-all shadow-xl active:scale-95 text-sm"
                >
                    + Divulgar Meu Grupo
                </a>
            </div>

            <ShowGroups grupos={gruposDaCategoria} />
        </Container>
    </Section>

    <Section class:list={"bg-gray-50 py-20 lg:py-32"}>
        <Container>
            <div class="max-w-3xl mx-auto text-center">
                <h2
                    class="text-3xl lg:text-4xl font-bold text-gray-950 mb-6 tracking-tight"
                >
                    Ainda procurando?
                </h2>
                <p class="text-gray-500 text-lg mb-12 font-medium">
                    Navegue por outras categorias populares para encontrar
                    exatamente o que deseja no WhatsApp.
                </p>
                <div class="flex flex-wrap justify-center gap-2">
                    {
                        todasCategorias
                            .slice(0, 15)
                            .filter((c) => c.slug !== categoria)
                            .map((cat) => (
                                <a
                                    href={`/categorias/${cat.slug}`}
                                    class="px-5 py-2.5 bg-white border border-gray-200 rounded-2xl text-sm text-gray-700 font-bold hover:bg-[#E8F8F5] hover:text-[#25D366] hover:border-[#25D366]/20 transition-all"
                                >
                                    {cat.label}
                                </a>
                            ))
                    }
                    <a
                        href="/categorias"
                        class="px-5 py-2.5 bg-gray-900 rounded-2xl text-sm text-white font-bold hover:bg-gray-800 transition-all"
                    >
                        Ver todas
                    </a>
                </div>
            </div>
        </Container>
    </Section>
</Layout>
